@model HeatGamesWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<style>
    /* ТЪМНО-ЛИЛАВ СТИЛ ЗА ФОРМИТЕ */
    .auth-card {
        background-color: #230046; /* Тъмно лилаво */
        border: 1px solid #4a0080; /* Средно лилаво */
        border-radius: 8px;
        color: #e6d9ff; /* Светло лилав текст */
    }

    .auth-input {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .auth-input:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff; /* Ярко лилаво при цъкане */
            box-shadow: 0 0 0 0.25rem rgba(190, 0, 255, 0.25);
        }

    .form-check-input {
        background-color: #000000;
        border-color: #4a0080;
    }

        .form-check-input:checked {
            background-color: #be00ff;
            border-color: #be00ff;
        }

    .btn-auth {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        font-weight: bold;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-auth:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    .auth-link {
        color: #be00ff;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

        .auth-link:hover {
            color: #ffffff;
            text-decoration: underline;
        }
</style>

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <i class="bi bi-person-circle" style="font-size: 4rem; color: #be00ff;"></i>
            <h2 class="mt-2 text-white fw-bold">ВХОД</h2>
            <p style="color: #c4a6ff;">Добре дошли отново в HeatGames!</p>
        </div>

        <form asp-action="Login" method="post" class="auth-card p-4 shadow-lg">
            <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-4">
                <label asp-for="Username" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-person"></i></span>
                    <input asp-for="Username" class="form-control auth-input" placeholder="Въведете потребителско име..." />
                </div>
                <span asp-validation-for="Username" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control auth-input" placeholder="Въведете парола..." />
                </div>
                <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-auth w-100 py-2 fs-5">Влез <i class="bi bi-box-arrow-in-right ms-1"></i></button>

            <hr style="border-color: #4a0080;" class="my-4" />

            <div class="text-center">
                Нямате акаунт? <a asp-action="Register" class="auth-link">Регистрирайте се тук</a>
            </div>
        </form>
    </div>
</div>