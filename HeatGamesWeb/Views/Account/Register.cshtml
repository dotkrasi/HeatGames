@model HeatGamesWeb.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
    .auth-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .auth-input {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .auth-input:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff;
            box-shadow: 0 0 0 0.25rem rgba(190, 0, 255, 0.25);
        }

    .btn-auth {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        font-weight: bold;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-auth:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    .auth-link {
        color: #be00ff;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

        .auth-link:hover {
            color: #ffffff;
            text-decoration: underline;
        }
</style>

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="text-center mb-4">
            <i class="bi bi-controller" style="font-size: 4rem; color: #be00ff;"></i>
            <h2 class="mt-2 text-white fw-bold">CREATE ACCOUNT</h2>
            <p style="color: #c4a6ff;">Join our gaming community!</p>
        </div>

        <form asp-action="Register" method="post" class="auth-card p-4 p-md-5 shadow-lg">
            <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

            <div class="mb-4">
                <label asp-for="Username" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-person-badge"></i></span>
                    <input asp-for="Username" class="form-control auth-input" placeholder="Choose a unique nickname..." />
                </div>
                <span asp-validation-for="Username" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control auth-input" placeholder="Enter your email..." />
                </div>
                <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" class="form-control auth-input" placeholder="Enter a secure password..." />
                </div>
                <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background-color: #4a0080; border: none; color: #fff;"><i class="bi bi-shield-check"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="Repeat your password..." />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold"></span>
            </div>

            <button type="submit" class="btn btn-auth w-100 py-2 fs-5 mt-2">Sign Up <i class="bi bi-person-plus-fill ms-1"></i></button>

            <hr style="border-color: #4a0080;" class="my-4" />

            <div class="text-center">
                Already have an account? <a asp-action="Login" class="auth-link">Login here</a>
            </div>
        </form>
    </div>
</div>