@model IEnumerable<HeatGamesWeb.ViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Моята Количка";
    decimal totalPrice = Model?.Sum(i => i.Price) ?? 0;
}

<style>
    /* Тъмен стил за количката */
    .cart-wrapper {
        background-color: #000000;
        min-height: 80vh;
        color: #e6d9ff;
    }

    .cart-header {
        font-size: 2rem;
        font-weight: bold;
        color: #ffffff;
        border-bottom: 2px solid #230046;
        padding-bottom: 10px;
        margin-bottom: 30px;
    }

    /* Карта за единична игра */
    .cart-item-card {
        background-color: #1a0033;
        border: 1px solid #4a0080;
        border-radius: 8px;
        margin-bottom: 15px;
        transition: 0.3s;
    }

        .cart-item-card:hover {
            background-color: #230046;
            border-color: #be00ff;
        }

    .cart-item-img {
        width: 120px;
        height: 70px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #4a0080;
    }

    .cart-item-title {
        font-size: 1.2rem;
        font-weight: bold;
        color: #ffffff;
    }

    .cart-item-price {
        font-size: 1.3rem;
        font-weight: bold;
        color: #be00ff;
    }

    .btn-remove {
        color: #ff4d4d;
        background: transparent;
        border: 1px solid #4a0080;
        transition: 0.2s;
        font-size: 0.9rem;
        padding: 5px 10px;
    }

        .btn-remove:hover {
            background: rgba(255, 77, 77, 0.1);
            color: #ff4d4d;
            border-color: #ff4d4d;
        }

    /* Дясна колона - Обобщение */
    .summary-card {
        background: linear-gradient(135deg, #1a0033 0%, #230046 100%);
        border: 1px solid #4a0080;
        border-radius: 8px;
        padding: 25px;
        position: sticky;
        top: 20px;
    }

    .summary-total {
        font-size: 2.2rem;
        font-weight: 900;
        color: #BEEF52; /* Неоново зелено за тотала */
        text-shadow: 0 0 10px rgba(190, 239, 82, 0.3);
    }

    .btn-checkout {
        background-color: #BEEF52;
        color: #000000;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 15px 20px;
        border: none;
        border-radius: 4px;
        width: 100%;
        transition: 0.2s;
        font-size: 1.2rem;
        margin-top: 20px;
    }

        .btn-checkout:hover {
            background-color: #d1ff70;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(190, 239, 82, 0.4);
        }

    .empty-cart-box {
        background-color: #1a0033;
        border: 1px dashed #4a0080;
        border-radius: 8px;
        padding: 50px 20px;
        text-align: center;
    }
</style>

<div class="cart-wrapper pt-4">
    <div class="container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;" role="alert">
                <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <h1 class="cart-header"><i class="bi bi-cart3 me-2" style="color: #be00ff;"></i> Вашата Количка</h1>

        @if (!Model.Any())
        {
            <div class="empty-cart-box">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #4a0080;"></i>
                <h3 class="mt-3 text-white">Количката ви е празна</h3>
                <p style="color: #acb1b8;">Все още не сте добавили никакви игри. Разгледайте нашия каталог!</p>
                <a asp-controller="Games" asp-action="Index" class="btn btn-outline-light mt-3 px-4 fw-bold">
                    Към Магазина
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-8">
                    @foreach (var item in Model)
                    {
                        <div class="cart-item-card p-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@item.CoverImageUrl" class="cart-item-img" alt="@item.Title">
                                <div>
                                    <div class="cart-item-title">@item.Title</div>
                                    <div class="text-muted small">Цифрово копие</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-4">
                                <div class="cart-item-price">
                                    @(item.Price == 0 ? "БЕЗПЛАТНО" : item.Price.ToString("0.00") + " лв.")
                                </div>
                                <form asp-controller="Cart" asp-action="Remove" method="post" class="m-0">
                                    <input type="hidden" name="gameId" value="@item.GameId" />
                                    <button type="submit" class="btn btn-remove rounded-1" title="Премахни">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div class="col-lg-4">
                    <div class="summary-card shadow-lg">
                        <h4 class="fw-bold text-white mb-4 border-bottom border-secondary pb-2">Обобщение</h4>

                        <div class="d-flex justify-content-between mb-3" style="color: #c4a6ff; font-size: 1.1rem;">
                            <span>Брой игри:</span>
                            <span class="fw-bold text-white">@Model.Count()</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-end mt-4 pt-3 border-top border-secondary">
                            <span style="color: #acb1b8; font-size: 1.2rem;">ОБЩО:</span>
                            <span class="summary-total">@totalPrice.ToString("0.00") лв.</span>
                        </div>

                        <form asp-controller="Orders" asp-action="Checkout" method="post">
                            <button type="submit" class="btn btn-checkout">
                                <i class="bi bi-wallet2 me-2 fs-5"></i> ПЛАТИ СЕГА
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a asp-controller="Games" asp-action="Index" style="color: #c4a6ff; text-decoration: none; font-size: 0.9rem;">
                                <i class="bi bi-arrow-left me-1"></i> Продължи пазаруването
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>