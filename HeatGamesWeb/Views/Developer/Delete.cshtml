@model HeatGames.Core.DTOs.DeveloperDto
@{
    ViewData["Title"] = "Изтрий Разработчик";
}

<style>
    /* ТЪМНО-ЛИЛАВ СТИЛ С ЧЕРВЕНИ АКЦЕНТИ ЗА ИЗТРИВАНЕ */
    .delete-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-top: 4px solid #dc3545; /* Червена линия отгоре за опасност */
        border-radius: 8px;
        color: #e6d9ff;
        padding: 40px 30px;
    }

    .delete-icon {
        color: #dc3545;
        text-shadow: 0 0 15px rgba(220, 53, 69, 0.4); /* Леко червено сияние */
    }

    .developer-name {
        color: #ffffff;
        font-size: 1.8rem;
        letter-spacing: 1px;
    }

    .warning-box {
        background-color: #1a0033;
        border: 1px dashed #dc3545; /* Червен пунктир за внимание */
        border-radius: 6px;
        padding: 15px;
    }

    .warning-text {
        color: #c4a6ff;
        font-size: 0.95rem;
    }

    /* Бутони */
    .btn-outline-purple {
        color: #c4a6ff;
        border: 1px solid #4a0080;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-purple:hover {
            background-color: #4a0080;
            color: white;
        }

    .btn-danger-custom {
        background-color: #dc3545;
        border: none;
        color: white;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-danger-custom:hover {
            background-color: #c82333;
            box-shadow: 0 4px 15px rgba(220, 53, 69, 0.5);
            transform: translateY(-2px);
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="delete-card shadow-lg text-center">
                <i class="bi bi-exclamation-triangle-fill fs-1 delete-icon mb-2 d-inline-block"></i>
                <h3 class="fw-bold text-white mb-4">Сигурни ли сте?</h3>

                <p class="fs-5 mb-2" style="color: #e6d9ff;">На път сте да изтриете студиото</p>
                <div class="developer-name fw-bold mb-4">@Model.Name</div>

                <div class="warning-box mx-auto mt-4 mb-4">
                    <p class="mb-0 warning-text text-start">
                        <i class="bi bi-info-circle me-2" style="color: #dc3545;"></i>
                        <strong>Внимание:</strong> Ако има игри, свързани с този разработчик, те също могат да бъдат изтрити (в зависимост от каскадното триене в базата).
                    </p>
                </div>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-purple fw-bold px-4 py-2">
                            <i class="bi bi-arrow-left me-1"></i> Отказ
                        </a>
                        <button type="submit" class="btn btn-danger-custom fw-bold px-4 py-2">
                            <i class="bi bi-trash me-1" style="color: white;"></i> Да, изтрий го!
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>