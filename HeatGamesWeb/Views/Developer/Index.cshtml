@model IEnumerable<HeatGames.Core.DTOs.DeveloperDto>
@{
    ViewData["Title"] = "Разработчици";
}

<style>
    /* ТЪМНО-ЛИЛАВ СТИЛ ЗА АДМИН ПАНЕЛА */
    .admin-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .table-dark-purple {
        color: #e6d9ff;
        background-color: transparent;
    }

        .table-dark-purple th {
            border-bottom: 2px solid #8d00c4;
            color: #c4a6ff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .table-dark-purple td {
            border-bottom: 1px solid #4a0080;
            vertical-align: middle;
        }

        .table-dark-purple tbody tr:hover {
            background-color: #1a0033;
        }

    /* Светещи линкове за уебсайтовете */
    .dev-link {
        color: #be00ff;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

        .dev-link:hover {
            color: #ffffff;
            text-decoration: underline;
            text-shadow: 0 0 8px rgba(190, 0, 255, 0.6);
        }

    .btn-magenta {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="color: #e6d9ff;" class="fw-bold">
                    <i class="bi bi-buildings-fill" style="color: #be00ff;"></i> Студиа / Разработчици
                </h2>

                <a asp-action="Create" class="btn btn-magenta fw-bold shadow-sm">
                    <i class="bi bi-plus-circle" style="color: white;"></i> Добави Студио
                </a>
            </div>

            <div class="admin-card shadow-lg p-4">
                @if (!Model.Any())
                {
                    <div class="alert text-center m-0" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff;">
                        <i class="bi bi-exclamation-circle fs-4 d-block mb-2"></i>
                        Все още няма добавени разработчици в базата.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-dark-purple table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Име на студиото</th>
                                    <th>Уебсайт</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-bold fs-5">
                                            <i class="bi bi-controller me-2 text-muted" style="font-size: 0.8rem;"></i> @item.Name
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Website))
                                            {
                                                <a href="@(item.Website.StartsWith("http") ? item.Website : "https://" + item.Website)" target="_blank" class="dev-link">
                                                    <i class="bi bi-link-45deg"></i> @item.Website
                                                </a>
                                            }
                                            else
                                            {
                                                <span style="color: #5d5462;"><i class="bi bi-dash-circle"></i> Няма сайт</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning fw-bold" title="Редактирай">
                                                <i class="bi bi-pencil" style="color: white;"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info fw-bold mx-1" title="Детайли">
                                                <i class="bi bi-info-circle" style="color: white;"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-bold" title="Изтрий">
                                                <i class="bi bi-trash" style="color: white;"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </div>
</div>