@model HeatGamesWeb.ViewModels.GameViewModel

@{
    ViewData["Title"] = "Add New Game";
}

<style>
    /* ТЪМНО-ЛИЛАВ СТИЛ ЗА АДМИН ПАНЕЛА */
    .admin-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .admin-header {
        background-color: #1a0033;
        border-bottom: 2px solid #8d00c4;
        border-radius: 8px 8px 0 0;
    }

    .admin-input, .form-select {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .admin-input:focus, .form-select:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff;
            box-shadow: 0 0 0 0.25rem rgba(190, 0, 255, 0.25);
        }

        .form-select option {
            background-color: #000000;
            color: #e6d9ff;
        }

    .input-group-text-dark {
        background-color: #4a0080;
        border: 1px solid #4a0080;
        color: #ffffff;
        font-weight: bold;
    }

    .btn-magenta {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    .form-check-input {
        background-color: #000;
        border-color: #4a0080;
    }

        .form-check-input:checked {
            background-color: #be00ff;
            border-color: #be00ff;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-8">
            <div class="admin-card shadow-lg">
                <div class="admin-header p-4 d-flex align-items-center gap-3">
                    <i class="bi bi-controller fs-2" style="color: #be00ff;"></i>
                    <h3 class="mb-0 text-white fw-bold">Add New Game</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold"><i class="bi bi-fonts me-1 text-muted"></i> Title</label>
                            <input asp-for="Title" class="form-control admin-input" placeholder="Enter game title..." />
                            <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold"><i class="bi bi-card-text me-1 text-muted"></i> Description</label>
                            <textarea asp-for="Description" class="form-control admin-input" rows="4" placeholder="Brief summary of the story and gameplay..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Price" class="form-label fw-bold"><i class="bi bi-tag-fill me-1 text-muted"></i> Price</label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control admin-input" type="number" step="0.01" placeholder="0.00" />
                                    <span class="input-group-text input-group-text-dark">BGN</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="ReleaseDate" class="form-label fw-bold"><i class="bi bi-calendar-date me-1 text-muted"></i> Release Date</label>
                                <input asp-for="ReleaseDate" class="form-control admin-input" type="date" />
                                <span asp-validation-for="ReleaseDate" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DeveloperId" class="form-label fw-bold"><i class="bi bi-building me-1 text-muted"></i> Developer (Studio)</label>
                            <select asp-for="DeveloperId" class="form-select admin-input" asp-items="ViewBag.Developers">
                                <option value="">-- Select Developer --</option>
                            </select>
                            <span asp-validation-for="DeveloperId" class="text-danger small fw-bold"></span>
                        </div>

                        @* 🎯 СЕКЦИЯ ЗА ЖАНРОВЕ (ДОБАВЕНА) *@
                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-tags-fill me-1 text-muted"></i> Genres</label>
                            <div class="d-flex flex-wrap gap-3 p-3 rounded" style="background-color: #1a0033; border: 1px solid #4a0080;">
                                @if (ViewBag.Genres != null)
                                {
                                    foreach (var genre in (IEnumerable<HeatGames.Core.DTOs.GenreDto>)ViewBag.Genres)
                                    {
                                        <div class="form-check form-check-inline m-0 me-3">
                                            <input class="form-check-input" type="checkbox" name="SelectedGenreIds" value="@genre.Id"
                                                   id="genre-@genre.Id" @(Model?.SelectedGenreIds?.Contains(genre.Id) == true ? "checked" : "")>
                                            <label class="form-check-label text-white" for="genre-@genre.Id">
                                                @genre.Name
                                            </label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">No genres available.</span>
                                }
                            </div>
                        </div>

                        @* СЕКЦИЯ ЗА ПЛАТФОРМИ *@
                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-pc-display me-1 text-muted"></i> Platforms</label>
                            <div class="d-flex flex-wrap gap-3 p-3 rounded" style="background-color: #1a0033; border: 1px solid #4a0080;">
                                @if (ViewBag.Platforms != null)
                                {
                                    foreach (var platform in (IEnumerable<HeatGames.Core.DTOs.PlatformDto>)ViewBag.Platforms)
                                    {
                                        <div class="form-check form-check-inline m-0 me-3">
                                            <input class="form-check-input" type="checkbox" name="SelectedPlatformIds" value="@platform.Id"
                                                   id="plt-@platform.Id" @(Model?.SelectedPlatformIds?.Contains(platform.Id) == true ? "checked" : "")>
                                            <label class="form-check-label text-white" for="plt-@platform.Id">
                                                @platform.Name
                                            </label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">No platforms available.</span>
                                }
                            </div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="CoverImageUrl" class="form-label fw-bold"><i class="bi bi-image me-1 text-muted"></i> Cover URL</label>
                            <input asp-for="CoverImageUrl" class="form-control admin-input" placeholder="https://..." />
                            <div class="form-text mt-1" style="color: #c4a6ff;">Enter the URL for the game cover (Steam image links recommended).</div>
                            <span asp-validation-for="CoverImageUrl" class="text-danger small fw-bold"></span>
                        </div>

                        <hr style="border-color: #4a0080;" class="my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Back to Catalog</a>
                            <button type="submit" class="btn btn-magenta fw-bold px-4 py-2"><i class="bi bi-cloud-arrow-up-fill me-1"></i> Save Game</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}