@model HeatGamesWeb.ViewModels.GameViewModel

@{
    ViewData["Title"] = "Delete Game";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger shadow-sm text-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                <h3 class="alert-heading mt-3">Are you sure?</h3>
                <p>You are about to delete the game <strong>@Model.Title</strong> forever from the catalog.</p>
                <hr>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-secondary">No, go back</a>
                        <button type="submit" class="btn btn-danger fw-bold">Yes, delete it!</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>