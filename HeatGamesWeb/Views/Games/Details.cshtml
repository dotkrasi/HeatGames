@model HeatGamesWeb.ViewModels.GameViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    @* ——— СЪОБЩЕНИЯ ОТ СЪРВЕРА (Успех или Грешка при покупка) ——— *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <strong>Грешка!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>Успех!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-lg">
        <div class="row g-0">
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" class="img-fluid rounded-start h-100" style="object-fit: cover;" alt="@Model.Title">
                }
                else
                {
                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center h-100 rounded-start">
                        <span>Няма снимка</span>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h1 class="card-title fw-bold mb-0">@Model.Title</h1>
                        <h2 class="text-success fw-bold mb-0">@Model.Price лв.</h2>
                    </div>

                    <p class="text-muted mb-4"><i class="bi bi-calendar-event"></i> Излязла на: @Model.ReleaseDate.ToString("dd.MM.yyyy")</p>

                    <h5 class="fw-bold">Описание:</h5>
                    <p class="card-text mb-4">@Model.Description</p>

                    @* ——— БУТОН "КУПИ" (Само за логнати потребители) ——— *@
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-controller="Orders" asp-action="Buy" method="post" class="mb-4">
                            <input type="hidden" name="gameId" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                                <i class="bi bi-cart-plus"></i> КУПИ ИГРАТА
                            </button>
                        </form>
                        <form asp-controller="Wishlist" asp-action="Toggle" method="post">
                            <input type="hidden" name="gameId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-lg shadow-sm" title="Добави/Премахни от Желани">
                                <i class="bi bi-heart-fill"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-4 text-center">
                            Трябва да влезете в профила си, за да купите тази игра.
                            <a asp-controller="Account" asp-action="Login" class="alert-link">Вход</a>
                        </div>
                    }

                    <div class="mt-4 d-flex gap-2 border-top pt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>

                        @* Админ бутоните си остават! *@
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Редактирай</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* ——— СЕКЦИЯ ЗА РЕВЮТА ——— *@
    <div class="mt-5">
        <h3 class="fw-bold mb-4"><i class="bi bi-chat-left-text"></i> Отзиви от играчи</h3>

        @* Форма за писане на ревю (Само за логнати) *@
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="card shadow-sm mb-4 border-0 bg-light">
                <div class="card-body">
                    <h5 class="fw-bold">Напишете ревю</h5>
                    <form asp-controller="Reviews" asp-action="Add" method="post">
                        <input type="hidden" name="gameId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Препоръчвате ли тази игра?</label>
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioYes" value="true" checked>
                                    <label class="form-check-label text-success fw-bold" for="radioYes"><i class="bi bi-hand-thumbs-up-fill"></i> Да</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioNo" value="false">
                                    <label class="form-check-label text-danger fw-bold" for="radioNo"><i class="bi bi-hand-thumbs-down-fill"></i> Не</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="comment" class="form-label fw-bold">Вашият коментар</label>
                            <textarea class="form-control" id="comment" name="comment" rows="3" required placeholder="Споделете мнението си за играта..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary fw-bold">Публикувай ревю</button>
                    </form>
                </div>
            </div>
        }

        @* Списък с публикуваните ревюта *@
        <div class="row g-3">
            @if (ViewBag.Reviews != null)
            {
                var reviews = (IEnumerable<HeatGames.Core.DTOs.ReviewDto>)ViewBag.Reviews;
                if (!reviews.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-secondary text-center">Все още няма ревюта за тази игра. Бъдете първият!</div>
                    </div>
                }
                else
                {
                    foreach (var review in reviews)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                    <span class="fw-bold"><i class="bi bi-person-circle"></i> @review.UserName</span>
                                    <span class="text-muted small">@review.CreatedOn.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="card-body">
                                    @if (review.IsPositive)
                                    {
                                        <h6 class="text-success fw-bold"><i class="bi bi-hand-thumbs-up-fill"></i> Препоръчва играта</h6>
                                    }
                                    else
                                    {
                                        <h6 class="text-danger fw-bold"><i class="bi bi-hand-thumbs-down-fill"></i> Не препоръчва играта</h6>
                                    }
                                    <p class="card-text mt-2">@review.Comment</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>