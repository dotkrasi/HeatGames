@model HeatGamesWeb.ViewModels.GameViewModel

@{
    ViewData["Title"] = Model.Title;
}

<style>
    /* СПЕЦИАЛНИ ТЪМНИ СТИЛОВЕ ЗА ДЕТАЙЛИТЕ НА ИГРАТА */
    .details-card {
        background-color: #230046; /* Тъмно лилаво */
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .details-price {
        color: #be00ff; /* Ярко лилаво (Магента) */
        font-size: 2.2rem;
        font-weight: 900;
        text-shadow: 0 0 10px rgba(190, 0, 255, 0.3);
    }

    /* Бутонът за Купуване (Магента) */
    .btn-magenta {
        background-color: #be00ff;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #d24dff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    /* Бутон за Wishlist */
    .btn-outline-magenta {
        color: #be00ff;
        border: 2px solid #be00ff;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-magenta:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
        }

    /* Ревюта */
    .review-form-card {
        background-color: #1a0033; /* Още по-тъмно за формата */
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

    .review-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

    .review-header {
        background-color: #1a0033;
        border-bottom: 1px solid #4a0080;
        color: #c4a6ff;
    }

    /* Тъмни Input полета */
    .form-control-dark {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .form-control-dark:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff;
            box-shadow: 0 0 0 0.25rem rgba(190, 0, 255, 0.25);
        }
</style>

<div class="container mt-5">
    @* ——— СЪОБЩЕНИЯ ОТ СЪРВЕРА ——— *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" style="background-color: #4d0000; color: #ffcccc; border: 1px solid #ff0000;" role="alert">
            <strong>Грешка!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;" role="alert">
            <strong>Успех!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="details-card shadow-lg overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="@Model.Title">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 w-100" style="background-color: #1a0033; min-height: 300px;">
                        <i class="bi bi-image" style="font-size: 4rem; color: #4a0080;"></i>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <div class="card-body p-5 d-flex flex-column h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h1 class="card-title fw-bold mb-0 text-white">@Model.Title</h1>
                        <span class="details-price">@Model.Price.ToString("0.00") лв.</span>
                    </div>

                    <p style="color: #c4a6ff;" class="mb-4">
                        <i class="bi bi-calendar-event"></i> Излязла на: @Model.ReleaseDate.ToString("dd.MM.yyyy")
                    </p>

                    <h5 class="fw-bold" style="color: #c4a6ff;">Описание:</h5>
                    <p class="card-text mb-5" style="line-height: 1.6;">@Model.Description</p>

                    <div class="mt-auto">
                        @* ——— БУТОНИ КУПИ / ЖЕЛАНИ / БИБЛИОТЕКА ——— *@
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            // Проверяваме дали потребителят вече притежава играта
                            bool ownsGame = ViewBag.OwnsGame as bool? ?? false;

                            if (ownsGame)
                            {
                                <div class="d-flex gap-3 mb-4">
                                    <div class="alert alert-success m-0 d-flex align-items-center justify-content-center" style="background-color: #1a0033; border: 1px dashed #BEEF52; color: #BEEF52; padding: 0 15px;" title="Вече притежавате тази игра">
                                        <i class="bi bi-check-circle-fill fs-4"></i>
                                    </div>
                                    <a asp-controller="Library" asp-action="Index" class="btn btn-lg w-100 fw-bold d-flex align-items-center justify-content-center" style="background-color: #BEEF52; color: #000000; transition: 0.2s; text-transform: uppercase; letter-spacing: 1px;">
                                        <i class="bi bi-collection-play-fill me-2 fs-5"></i> Към Библиотеката
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-3 mb-4">
                                    <form asp-controller="Orders" asp-action="Buy" method="post" class="flex-grow-1 m-0">
                                        <input type="hidden" name="gameId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-magenta btn-lg w-100 fw-bold h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cart-plus me-2 fs-5"></i> КУПИ ИГРАТА
                                        </button>
                                    </form>

                                    <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="m-0">
                                        <input type="hidden" name="gameId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-outline-magenta btn-lg h-100 d-flex align-items-center justify-content-center" style="padding-left: 1.5rem; padding-right: 1.5rem;" title="Добави/Премахни от Желани">
                                            <i class="bi bi-heart-fill fs-5"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert text-center mb-4" style="background-color: #1a0033; border: 1px solid #4a0080; color: #c4a6ff;">
                                Трябва да влезете в профила си, за да купите тази игра.
                                <a asp-controller="Account" asp-action="Login" class="fw-bold" style="color: #be00ff;">Вход</a>
                            </div>
                        }

                        <div class="d-flex gap-2 pt-3" style="border-top: 1px solid #4a0080;">
                            <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Назад към магазина</a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Редактирай</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ——— СЕКЦИЯ ЗА РЕВЮТА ——— *@
    <div class="mt-5 mb-5">
        <h3 class="fw-bold mb-4 text-white"><i class="bi bi-chat-left-text" style="color: #be00ff;"></i> Отзиви от играчи</h3>

        @* Форма за писане на ревю *@
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="card review-form-card shadow-sm mb-5 rounded">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: #c4a6ff;">Напишете ревю за играта</h5>
                    <form asp-controller="Reviews" asp-action="Add" method="post">
                        <input type="hidden" name="gameId" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Препоръчвате ли тази игра?</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioYes" value="true" checked style="background-color: #000; border-color: #4a0080;">
                                    <label class="form-check-label text-success fw-bold fs-5" for="radioYes">
                                        <i class="bi bi-hand-thumbs-up-fill"></i> Да
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioNo" value="false" style="background-color: #000; border-color: #4a0080;">
                                    <label class="form-check-label text-danger fw-bold fs-5" for="radioNo">
                                        <i class="bi bi-hand-thumbs-down-fill"></i> Не
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="comment" class="form-label fw-bold">Вашият коментар</label>
                            <textarea class="form-control form-control-dark" id="comment" name="comment" rows="3" required placeholder="Споделете мнението си..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-magenta fw-bold px-4">Публикувай ревю</button>
                    </form>
                </div>
            </div>
        }

        @* Списък с публикуваните ревюта *@
        <div class="row g-4">
            @if (ViewBag.Reviews != null)
            {
                var reviews = (IEnumerable<HeatGames.Core.DTOs.ReviewDto>)ViewBag.Reviews;
                if (!reviews.Any())
                {
                    <div class="col-12">
                        <div class="alert text-center py-5" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff;">
                            <i class="bi bi-chat-square-dots fs-1 mb-3 d-block"></i>
                            Все още няма ревюта за тази игра. Бъдете първият!
                        </div>
                    </div>
                }
                else
                {
                    foreach (var review in reviews)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm review-card rounded">
                                <div class="card-header review-header d-flex justify-content-between align-items-center py-3">
                                    <span class="fw-bold text-white"><i class="bi bi-person-circle me-2"></i>@review.UserName</span>
                                    <span class="small" style="color: #8d00c4;">@review.CreatedOn.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="card-body p-4">
                                    @if (review.IsPositive)
                                    {
                                        <h6 class="text-success fw-bold mb-3"><i class="bi bi-hand-thumbs-up-fill fs-5 me-2"></i> Препоръчва играта</h6>
                                    }
                                    else
                                    {
                                        <h6 class="text-danger fw-bold mb-3"><i class="bi bi-hand-thumbs-down-fill fs-5 me-2"></i> Не препоръчва играта</h6>
                                    }
                                    <p class="card-text" style="color: #e6d9ff; line-height: 1.5;">@review.Comment</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>  