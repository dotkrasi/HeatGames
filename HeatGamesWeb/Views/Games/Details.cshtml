@model HeatGamesWeb.ViewModels.GameViewModel

@{
    ViewData["Title"] = Model.Title;
}

<style>
    /* СПЕЦИАЛНИ ТЪМНИ СТИЛОВЕ ЗА ДЕТАЙЛИТЕ НА ИГРАТА */
    .details-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .details-price {
        color: #be00ff;
        font-size: 2.2rem;
        font-weight: 900;
        text-shadow: 0 0 10px rgba(190, 0, 255, 0.3);
    }

    /* Бутонът за Купуване (Магента) */
    .btn-magenta {
        background-color: #be00ff;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #d24dff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    /* Бутон за Wishlist (Недобавена игра) */
    .btn-outline-magenta {
        color: #be00ff;
        border: 2px solid #be00ff;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-magenta:hover {
            background-color: rgba(190, 0, 255, 0.1);
            color: #be00ff;
        }

    /* 🎯 НОВ СТИЛ ЗА АКТИВЕН WISHLIST (НЕОНОВО РОЗОВО) */
    .btn-wishlist-active {
        background-color: #ff3366 !important;
        border-color: #ff3366 !important;
        color: white !important;
        box-shadow: 0 0 20px rgba(255, 51, 102, 0.6) !important;
    }

    /* Бутон In Cart (когато вече е добавена) */
    .btn-in-cart {
        background-color: #BEEF52;
        color: #000000;
        border: none;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: default;
    }

    /* Ревюта */
    .review-form-card {
        background-color: #1a0033;
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

    .review-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

    .review-header {
        background-color: #1a0033;
        border-bottom: 1px solid #4a0080;
        color: #c4a6ff;
    }

    /* Тъмни Input полета */
    .form-control-dark {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .form-control-dark:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff;
            box-shadow: 0 0 0 0.25rem rgba(190, 0, 255, 0.25);
        }

    .badge-genre {
        background-color: #8d00c4;
        color: white;
        padding: 6px 12px;
        font-size: 0.85rem;
    }

    .badge-platform {
        background-color: rgba(190, 0, 255, 0.1);
        border: 1px solid #be00ff;
        color: #e6d9ff;
        padding: 6px 12px;
        font-size: 0.85rem;
    }
</style>

<div class="container mt-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" style="background-color: #4d0000; color: #ffcccc; border: 1px solid #ff0000;" role="alert">
            <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="details-card shadow-lg overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-5">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="@Model.Title">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 w-100" style="background-color: #1a0033; min-height: 300px;">
                        <i class="bi bi-image" style="font-size: 4rem; color: #4a0080;"></i>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <div class="card-body p-5 d-flex flex-column h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h1 class="card-title fw-bold mb-0 text-white">@Model.Title</h1>
                            <p class="mt-1 mb-0" style="font-size: 1.1rem; color: #acb1b8;">Developed by: <span style="color: #00d2ff; font-weight: bold;">@Model.DeveloperName</span></p>
                        </div>
                        <span class="details-price">@(Model.Price == 0 ? "FREE" : Model.Price.ToString("0.00") + " BGN")</span>
                    </div>

                    <p style="color: #c4a6ff;" class="mb-4">
                        <i class="bi bi-calendar-event me-1"></i> Release Date: @Model.ReleaseDate.ToString("dd.MM.yyyy")
                    </p>

                    @if (Model.Genres != null && Model.Genres.Any())
                    {
                        <div class="mb-3">
                            <span class="fw-bold d-block mb-2" style="color: #c4a6ff; font-size: 0.9rem;">GENRES:</span>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var genre in Model.Genres)
                                {
                                    <span class="badge rounded-pill badge-genre">@genre</span>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.Platforms != null && Model.Platforms.Any())
                    {
                        <div class="mb-4">
                            <span class="fw-bold d-block mb-2" style="color: #c4a6ff; font-size: 0.9rem;">AVAILABLE ON:</span>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var platform in Model.Platforms)
                                {
                                    <span class="badge badge-platform">
                                        @if (platform.Contains("PC"))
                                        {
                                            <i class="bi bi-windows me-1"></i>
                                        }
                                        else if (platform.Contains("PlayStation"))
                                        {

                                            <i class="bi bi-playstation me-1"></i>
                                        }
                                        else if (platform.Contains("Xbox"))
                                        {

                                            <i class="bi bi-xbox me-1"></i>
                                        }
                                        else if (platform.Contains("Switch"))
                                        {

                                            <i class="bi bi-nintendo-switch me-1"></i>
                                        }
                                        @platform
                                    </span>
                                }
                            </div>
                        </div>
                    }

                    <h5 class="fw-bold mt-2" style="color: #c4a6ff;">DESCRIPTION:</h5>
                    <p class="card-text mb-5" style="line-height: 1.6;">@Model.Description</p>

                    <div class="mt-auto">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            bool ownsGame = ViewBag.OwnsGame as bool? ?? false;

                            if (ownsGame)
                            {
                                <div class="d-flex gap-3 mb-4">
                                    <div class="alert alert-success m-0 d-flex align-items-center justify-content-center" style="background-color: #1a0033; border: 1px dashed #BEEF52; color: #BEEF52; padding: 0 15px;">
                                        <i class="bi bi-check-circle-fill fs-4"></i>
                                    </div>
                                    <a asp-controller="Library" asp-action="Index" class="btn btn-lg w-100 fw-bold d-flex align-items-center justify-content-center" style="background-color: #BEEF52; color: #000000; text-transform: uppercase;">
                                        <i class="bi bi-collection-play-fill me-2 fs-5"></i> IN LIBRARY
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-3 mb-4">
                                    @if (Model.IsInCart)
                                    {
                                        <button disabled class="btn btn-in-cart btn-lg w-100 h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cart-check-fill me-2 fs-5"></i> IN CART
                                        </button>
                                    }
                                    else
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1 m-0">
                                            <input type="hidden" name="gameId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-magenta btn-lg w-100 fw-bold h-100">ADD TO CART</button>
                                        </form>
                                    }

                                    <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="m-0">
                                        <input type="hidden" name="gameId" value="@Model.Id" />
                                        <button type="submit"
                                                class="btn btn-lg h-100 d-flex align-items-center justify-content-center
                                                                        @(Model.IsInWishlist ? "btn-wishlist-active" : "btn-outline-magenta")"
                                                style="padding-left: 1.5rem; padding-right: 1.5rem;"
                                                title="@(Model.IsInWishlist ? "Remove from Wishlist" : "Add to Wishlist")">
                                            <i class="bi @(Model.IsInWishlist ? "bi-heart-fill" : "bi-heart") fs-5"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert text-center mb-4" style="background-color: #1a0033; border: 1px solid #4a0080; color: #c4a6ff;">
                                Please <a asp-controller="Account" asp-action="Login" class="fw-bold" style="color: #be00ff;">Sign In</a> to purchase.
                            </div>
                        }

                        <div class="d-flex gap-2 pt-3" style="border-top: 1px solid #4a0080;">
                            <a asp-action="Index" class="btn btn-outline-light">Back to Store</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ——— СЕКЦИЯ ЗА РЕВЮТА ——— *@
    <div class="mt-5 mb-5">
        <h3 class="fw-bold mb-4 text-white"><i class="bi bi-chat-left-text" style="color: #be00ff;"></i> Player Reviews</h3>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="card review-form-card shadow-sm mb-5 rounded">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: #c4a6ff;">Write a review for this game</h5>
                    <form asp-controller="Reviews" asp-action="Add" method="post">
                        <input type="hidden" name="gameId" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Do you recommend this game?</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioYes" value="true" checked style="background-color: #000; border-color: #4a0080;">
                                    <label class="form-check-label text-success fw-bold fs-5" for="radioYes">
                                        <i class="bi bi-hand-thumbs-up-fill"></i> Yes
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="isPositive" id="radioNo" value="false" style="background-color: #000; border-color: #4a0080;">
                                    <label class="form-check-label text-danger fw-bold fs-5" for="radioNo">
                                        <i class="bi bi-hand-thumbs-down-fill"></i> No
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="comment" class="form-label fw-bold">Your Comment</label>
                            <textarea class="form-control form-control-dark" id="comment" name="comment" rows="3" required placeholder="Share your thoughts..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-magenta fw-bold px-4">Post Review</button>
                    </form>
                </div>
            </div>
        }

        <div class="row g-4">
            @if (ViewBag.Reviews != null)
            {
                var reviews = (IEnumerable<HeatGames.Core.DTOs.ReviewDto>)ViewBag.Reviews;
                if (!reviews.Any())
                {
                    <div class="col-12">
                        <div class="alert text-center py-5" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff;">
                            <i class="bi bi-chat-square-dots fs-1 mb-3 d-block"></i>
                            There are no reviews for this game yet. Be the first!
                        </div>
                    </div>
                }
                else
                {
                    foreach (var review in reviews)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm review-card rounded">
                                <div class="card-header review-header d-flex justify-content-between align-items-center py-3">
                                    <span class="fw-bold text-white"><i class="bi bi-person-circle me-2"></i>@review.UserName</span>
                                    <span class="small" style="color: #8d00c4;">@review.CreatedOn.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="card-body p-4">
                                    @if (review.IsPositive)
                                    {
                                        <h6 class="text-success fw-bold mb-3"><i class="bi bi-hand-thumbs-up-fill fs-5 me-2"></i> Recommends this game</h6>
                                    }
                                    else
                                    {
                                        <h6 class="text-danger fw-bold mb-3"><i class="bi bi-hand-thumbs-down-fill fs-5 me-2"></i> Doesn't recommend this game</h6>
                                    }
                                    <p class="card-text" style="color: #e6d9ff; line-height: 1.5;">@review.Comment</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>