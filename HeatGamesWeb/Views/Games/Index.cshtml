@model IEnumerable<HeatGamesWeb.ViewModels.GameViewModel>

@{
    ViewData["Title"] = "Каталог с игри";

    // Взимаме първата игра само за рекламния банер отгоре (Само ако няма филтри!)
    bool hasFilters = !string.IsNullOrEmpty(ViewBag.CurrentSearch) || !string.IsNullOrEmpty(ViewBag.CurrentGenre) || ViewBag.CurrentMaxPrice != null;

    var featuredGame = hasFilters ? null : Model.FirstOrDefault();

    // Ако има банер, го прескачаме в решетката долу
    var displayGames = featuredGame != null ? Model.Skip(1) : Model;
}

<style>
    .store-sidebar {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 4px;
        padding: 15px;
    }

    .store-sidebar-link {
        color: #e6d9ff;
        text-decoration: none;
        display: block;
        padding: 8px 10px;
        font-size: 14px;
        transition: 0.2s;
    }

        .store-sidebar-link:hover, .store-sidebar-link.active {
            background-color: #4a0080;
            color: #ffffff;
            border-radius: 4px;
        }

    /* Банерът за първата игра */
    .featured-game-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 30px;
    }

    .featured-game-img {
        width: 100%;
        height: 350px;
        object-fit: cover;
    }

    /* Малките карти */
    .game-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 4px;
        transition: border-color 0.2s, transform 0.2s;
    }

        .game-card:hover {
            border-color: #be00ff;
            transform: translateY(-3px);
        }

    .game-card-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 4px 4px 0 0;
    }

    /* Цветове за цени и бутони */
    .price-text {
        font-size: 18px;
        font-weight: bold;
        color: #be00ff;
    }

    .price-text-sm {
        font-size: 14px;
        font-weight: bold;
        color: #be00ff;
    }

    .btn-purple {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
    }

        .btn-purple:hover {
            background-color: #be00ff;
            color: #ffffff;
        }

    .btn-outline-purple {
        color: #be00ff;
        border: 1px solid #be00ff;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-purple:hover {
            background-color: #be00ff;
            color: #ffffff;
        }

    /* Стил за търсачката */
    .search-input {
        background-color: #000000;
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

        .search-input:focus {
            background-color: #1a0033;
            border-color: #be00ff;
            color: #ffffff;
            box-shadow: none;
        }

    /* Стил за пагинация */
    .page-link-dark {
        background-color: #1a0033;
        border-color: #4a0080;
        color: #c4a6ff;
    }

    .page-item.active .page-link-dark {
        background-color: #be00ff;
        border-color: #be00ff;
        color: white;
    }

    .page-link-dark:hover {
        background-color: #4a0080;
        color: white;
    }
</style>

<div class="row mt-4">
    <div class="col-md-3 col-lg-2 mb-4">

        <div class="mb-4">
            <form asp-action="Index" method="get">
                @if (!string.IsNullOrEmpty(ViewBag.CurrentGenre))
                {
                    <input type="hidden" name="genre" value="@ViewBag.CurrentGenre" />
                }
                @if (ViewBag.CurrentMaxPrice != null)
                {
                    <input type="hidden" name="maxPrice" value="@ViewBag.CurrentMaxPrice" />
                }

                <div class="input-group shadow-sm">
                    <input type="text" name="searchQuery" value="@ViewBag.CurrentSearch" class="form-control search-input" placeholder="Търси игра...">
                    <button class="btn btn-purple" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
        </div>

        <div class="store-sidebar shadow-sm">
            <h6 class="text-uppercase fw-bold mb-3" style="color: #c4a6ff; font-size: 12px; letter-spacing: 1px;">Жанрове</h6>
            <nav class="nav flex-column">
                <a asp-action="Index" asp-route-maxPrice="@ViewBag.CurrentMaxPrice" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(string.IsNullOrEmpty(ViewBag.CurrentGenre) ? "active fw-bold" : "")">Всички жанрове</a>

                @if (ViewBag.Genres != null)
                {
                    foreach (var genre in (IEnumerable<HeatGames.Core.DTOs.GenreDto>)ViewBag.Genres)
                    {
                        // Взимаме само първата дума от жанра за линка
                        string genreWord = genre.Name.Split(' ')[0];
                        bool isActive = ViewBag.CurrentGenre == genreWord || ViewBag.CurrentGenre == genre.Name;

                        <a asp-action="Index" asp-route-genre="@genre.Name" asp-route-maxPrice="@ViewBag.CurrentMaxPrice" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(isActive ? "active fw-bold" : "")">
                            @genre.Name
                        </a>
                    }
                }
            </nav>

            <hr style="border-color: #4a0080;" class="my-4" />

            <h6 class="text-uppercase fw-bold mb-3" style="color: #c4a6ff; font-size: 12px; letter-spacing: 1px;">Цена</h6>
            <nav class="nav flex-column">
                <a asp-action="Index" asp-route-genre="@ViewBag.CurrentGenre" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(ViewBag.CurrentMaxPrice == null ? "active fw-bold" : "")">Всички цени</a>
                <a asp-action="Index" asp-route-maxPrice="10" asp-route-genre="@ViewBag.CurrentGenre" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(ViewBag.CurrentMaxPrice == 10m ? "active fw-bold" : "")">Под 10 лв.</a>
                <a asp-action="Index" asp-route-maxPrice="20" asp-route-genre="@ViewBag.CurrentGenre" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(ViewBag.CurrentMaxPrice == 20m ? "active fw-bold" : "")">Под 20 лв.</a>
                <a asp-action="Index" asp-route-maxPrice="50" asp-route-genre="@ViewBag.CurrentGenre" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(ViewBag.CurrentMaxPrice == 50m ? "active fw-bold" : "")">Под 50 лв.</a>
                <a asp-action="Index" asp-route-maxPrice="0" asp-route-genre="@ViewBag.CurrentGenre" asp-route-searchQuery="@ViewBag.CurrentSearch" class="store-sidebar-link @(ViewBag.CurrentMaxPrice == 0m ? "active fw-bold text-success" : "")">Безплатни</a>
            </nav>

            @if (hasFilters)
            {
                <div class="mt-4 text-center">
                    <a asp-action="Index" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-x-circle"></i> Изчисти филтрите</a>
                </div>
            }
        </div>
    </div>

    <div class="col-md-9 col-lg-10">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: #e6d9ff;">
                @if (hasFilters)
                {
                    <span>Резултати от търсенето (@ViewBag.TotalCount)</span>
                }
                else
                {
                    <span>Магазин</span>
                }
            </h2>

            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-purple shadow-sm">
                    <i class="bi bi-plus-circle"></i> Добави нова игра
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="alert text-center py-5 shadow-sm" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff; border-radius: 8px;">
                <i class="bi bi-search fs-1 d-block mb-3"></i>
                <h4 class="text-white">Няма намерени игри</h4>
                <p>Опитайте да промените филтрите или да потърсите с друго име.</p>
                <a asp-action="Index" class="btn btn-outline-purple mt-2">Виж всички игри</a>
            </div>
        }
        else
        {
            @if (featuredGame != null)
            {
                <div class="featured-game-card shadow-lg">
                    <div class="row g-0">
                        <div class="col-md-8">
                            @if (!string.IsNullOrEmpty(featuredGame.CoverImageUrl))
                            {
                                <a asp-action="Details" asp-route-id="@featuredGame.Id">
                                    <img src="@featuredGame.CoverImageUrl" class="featured-game-img" alt="@featuredGame.Title">
                                </a>
                            }
                        </div>
                        <div class="col-md-4">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <h3 class="card-title fw-bold text-white mb-2">@featuredGame.Title</h3>

                                <p class="card-text mt-3" style="color: #c4a6ff; font-size: 14px;">
                                    Избрана игра за тази седмица. Не пропускайте възможността да я добавите в библиотеката си!
                                </p>

                                <div class="mt-auto pt-4 text-end">
                                    <span class="price-text me-3">@featuredGame.Price.ToString("0.00") лв.</span>
                                    <a asp-action="Details" asp-route-id="@featuredGame.Id" class="btn btn-purple fw-bold px-4">Детайли</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!hasFilters)
            {
                <h4 class="fw-bold mb-3 mt-5" style="color: #e6d9ff;">Всички игри</h4>
            }

            <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var item in displayGames)
                {
                    <div class="col">
                        <div class="card h-100 game-card shadow-sm border-0">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@item.CoverImageUrl" class="game-card-img" alt="@item.Title">
                                }
                                else
                                {
                                    <div class="game-card-img bg-dark d-flex align-items-center justify-content-center">
                                        <i class="bi bi-image fs-1 text-secondary"></i>
                                    </div>
                                }
                            </a>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title fw-bold mb-1" style="color: #ffffff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.Title">
                                    @item.Title
                                </h6>

                                @* ДОБАВЕНО: Платформи *@
                                <div class="mb-2">
                                    @if (item.Platforms != null && item.Platforms.Any())
                                    {
                                        @foreach (var plt in item.Platforms.Take(3))
                                        {
                                            <span class="badge me-1 text-uppercase" style="background-color: #4a0080; font-size: 10px; border: 1px solid #8d00c4;">@plt</span>
                                        }
                                    }
                                </div>

                                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                                    @if (item.Price == 0)
                                    {
                                        <span class="price-text-sm text-success">БЕЗПЛАТНО</span>
                                    }
                                    else
                                    {
                                        <span class="price-text-sm">@item.Price.ToString("0.00") лв.</span>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-purple fw-bold px-3">Детайли</a>
                                </div>

                                @if (User.IsInRole("Admin"))
                                {
                                    <hr class="mt-3 mb-2" style="border-color: #4a0080;" />
                                    <div class="d-grid gap-1 d-md-flex justify-content-md-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning w-100" style="font-size: 12px; padding: 4px;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100" style="font-size: 12px; padding: 4px;">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* ——— ПАГИНАЦИЯ ——— *@
            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                int currentPage = ViewBag.CurrentPage;
                int totalPages = ViewBag.TotalPages;

                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link page-link-dark" asp-action="Index"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-searchQuery="@ViewBag.CurrentSearch"
                               asp-route-genre="@ViewBag.CurrentGenre"
                               asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                &laquo;
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link page-link-dark" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchQuery="@ViewBag.CurrentSearch"
                                   asp-route-genre="@ViewBag.CurrentGenre"
                                   asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link page-link-dark" asp-action="Index"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-searchQuery="@ViewBag.CurrentSearch"
                               asp-route-genre="@ViewBag.CurrentGenre"
                               asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                &raquo;
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>