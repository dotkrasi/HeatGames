@model IEnumerable<HeatGamesWeb.ViewModels.GameViewModel>

@{
    ViewData["Title"] = "Каталог с игри";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Всички игри</h2>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Добави нова игра
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-lg">
                @* Направихме и самата снимка да може да се цъка! *@
                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                    @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                    {
                        <img src="@item.CoverImageUrl" class="card-img-top rounded-top" alt="@item.Title" style="height: 250px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary text-white d-flex align-items-center justify-content-center rounded-top" style="height: 250px;">
                            <i class="bi bi-image fs-1"></i>
                        </div>
                    }
                </a>

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold">@item.Title</h5>
                    <p class="card-text fw-bold text-success fs-5">@item.Price лв.</p>

                    @* ——— БУТОН ЗА КЛИЕНТИ (Винаги най-отдолу) ——— *@
                    <div class="mt-auto pt-3">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 fw-bold shadow-sm">
                            <i class="bi bi-info-circle"></i> Виж детайли
                        </a>
                    </div>

                    @* ——— АДМИН БУТОНИ ——— *@
                    @if (User.IsInRole("Admin"))
                    {
                        <hr class="mt-3 mb-3" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning w-100">
                                <i class="bi bi-pencil"></i> Редакция
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100">
                                <i class="bi bi-trash"></i> Изтрий
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        Все още няма добавени игри в каталога.
    </div>
}