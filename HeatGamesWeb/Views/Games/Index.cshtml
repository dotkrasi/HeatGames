@model IEnumerable<HeatGamesWeb.ViewModels.GameViewModel>

@{
    ViewData["Title"] = "Store";

    // 🎯 ДОБАВЕНО: Проверка и за CurrentDeveloperId
    bool hasFilters = !string.IsNullOrEmpty(ViewBag.CurrentSearch) ||
                      !string.IsNullOrEmpty(ViewBag.CurrentGenre) ||
                      ViewBag.CurrentMaxPrice != null ||
                      ViewBag.CurrentMinPrice != null ||
                      ViewBag.CurrentDeveloperId != null;

    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    bool isFirstPage = currentPage == 1;

    HeatGamesWeb.ViewModels.GameViewModel featuredGame = null;

    IEnumerable<HeatGamesWeb.ViewModels.GameViewModel> displayGames = Model;

    if (!hasFilters && isFirstPage && Model.Any())
    {
        int totalGames = Model.Count();
        var now = DateTime.Now;
        int timeSeed = now.Year + now.Month + now.Day + now.Hour + now.Minute;

        Random seededRandom = new Random(timeSeed);
        int randomIndex = seededRandom.Next(0, totalGames);

        featuredGame = Model.ElementAt(randomIndex);
    }
}

<style>
    .store-sidebar {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        padding: 20px;
    }

    .featured-game-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 30px;
    }

    .featured-game-img {
        width: 100%;
        height: 350px;
        object-fit: cover;
    }

    .game-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 4px;
        transition: border-color 0.2s, transform 0.2s;
        position: relative;
    }

        .game-card:hover {
            border-color: #be00ff;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(190, 0, 255, 0.15);
        }

    .game-card-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 4px 4px 0 0;
    }

    .indicator-container {
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        gap: 8px;
        z-index: 10;
        pointer-events: none;
    }

    .indicator-icon {
        background-color: rgba(0, 0, 0, 0.7);
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .wishlist-active {
        color: #ff3366;
        border: 1px solid #ff3366;
        text-shadow: 0 0 8px #ff3366;
    }

    .cart-active {
        color: #BEEF52;
        border: 1px solid #BEEF52;
        text-shadow: 0 0 8px #BEEF52;
    }

    .price-text {
        font-size: 18px;
        font-weight: bold;
        color: #be00ff;
    }

    .price-text-sm {
        font-size: 14px;
        font-weight: bold;
        color: #be00ff;
    }

    .btn-purple {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        transition: 0.2s;
    }

        .btn-purple:hover {
            background-color: #be00ff;
            color: #ffffff;
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    .btn-outline-purple {
        color: #be00ff;
        border: 1px solid #be00ff;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-purple:hover {
            background-color: #be00ff;
            color: #ffffff;
        }

    .filter-input {
        background-color: #000000;
        border: 1px solid #4a0080;
        color: #e6d9ff;
    }

        .filter-input:focus {
            background-color: #1a0033;
            border-color: #be00ff;
            color: #ffffff;
            box-shadow: 0 0 5px rgba(190, 0, 255, 0.5);
        }

    .form-select.filter-input {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23e6d9ff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
    }

    .page-link-dark {
        background-color: #1a0033;
        border-color: #4a0080;
        color: #c4a6ff;
    }

    .page-item.active .page-link-dark {
        background-color: #be00ff;
        border-color: #be00ff;
        color: white;
    }

    .page-link-dark:hover {
        background-color: #4a0080;
        color: white;
    }
</style>

<div class="row mt-4 mb-5">
    <div class="col-md-4 col-lg-3 mb-4">
        <div class="store-sidebar shadow-lg sticky-top" style="top: 20px; z-index: 99;">
            <h5 class="text-uppercase fw-bold mb-4 border-bottom border-secondary pb-2" style="color: #e6d9ff;">
                <i class="bi bi-funnel-fill" style="color: #be00ff;"></i> Filters
            </h5>

            <form asp-action="Index" method="get">

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-1">GAME TITLE</label>
                    <div class="input-group">
                        <span class="input-group-text filter-input border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchQuery" value="@ViewBag.CurrentSearch" class="form-control filter-input border-start-0 ps-0" placeholder="Search...">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-1">GENRE</label>
                    <select name="genre" class="form-select filter-input">
                        <option value="">All Genres</option>
                        @if (ViewBag.Genres != null)
                        {
                            foreach (var genre in (IEnumerable<HeatGames.Core.DTOs.GenreDto>)ViewBag.Genres)
                            {
                                if (ViewBag.CurrentGenre == genre.Name)
                                {
                                    <option value="@genre.Name" selected>@genre.Name</option>
                                }
                                else
                                {
                                    <option value="@genre.Name">@genre.Name</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-1">DEVELOPER</label>
                    <select name="developerId" class="form-select filter-input">
                        <option value="">All Developers</option>
                        @if (ViewBag.Developers != null)
                        {
                            // Предполагам, че моделът ти за Developer e DeveloperDto
                            foreach (var dev in (IEnumerable<HeatGames.Core.DTOs.DeveloperDto>)ViewBag.Developers)
                            {
                                if (ViewBag.CurrentDeveloperId != null && ViewBag.CurrentDeveloperId.ToString() == dev.Id.ToString())
                                {
                                    <option value="@dev.Id" selected>@dev.Name</option>
                                }
                                else
                                {
                                    <option value="@dev.Id">@dev.Name</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-1">PRICE (BGN)</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" name="minPrice" value="@ViewBag.CurrentMinPrice" class="form-control filter-input text-center" placeholder="Min" min="0" step="0.01">
                        <span style="color: #acb1b8;">-</span>
                        <input type="number" name="maxPrice" value="@ViewBag.CurrentMaxPrice" class="form-control filter-input text-center" placeholder="Max" min="0" step="0.01">
                    </div>
                </div>

                <button type="submit" class="btn btn-purple w-100 fw-bold py-2 mb-2">
                    APPLY FILTERS
                </button>

                @if (hasFilters)
                {
                    <a asp-action="Index" class="btn btn-outline-danger w-100 fw-bold border-0 mt-1">
                        <i class="bi bi-x-circle me-1"></i> Clear All
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="col-md-8 col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: #e6d9ff;" class="fw-bold">
                @if (hasFilters)
                {
                    <span><i class="bi bi-list-stars me-2 text-info"></i> Results (@ViewBag.TotalCount)</span>
                }
                else
                {
                    <span><i class="bi bi-shop me-2 text-info"></i> Store Catalog</span>
                }
            </h2>

            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-purple shadow-sm fw-bold">
                    <i class="bi bi-plus-circle me-1"></i> Add Game
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="alert text-center py-5 shadow-sm" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff; border-radius: 8px;">
                <i class="bi bi-search fs-1 d-block mb-3"></i>
                <h4 class="text-white fw-bold">No games found</h4>
                <p>Try adjusting your filters or price range.</p>
                <a asp-action="Index" class="btn btn-outline-purple mt-2 fw-bold">View All Games</a>
            </div>
        }
        else
        {
            @if (featuredGame != null)
            {
                <div class="featured-game-card shadow-lg">
                    <div class="row g-0">
                        <div class="col-md-8">
                            @if (!string.IsNullOrEmpty(featuredGame.CoverImageUrl))
                            {
                                <a asp-action="Details" asp-route-id="@featuredGame.Id">
                                    <img src="@featuredGame.CoverImageUrl" class="featured-game-img" alt="@featuredGame.Title">
                                </a>
                            }
                        </div>
                        <div class="col-md-4">
                            <div class="card-body p-4 d-flex flex-column h-100" style="background-color: #230046;">
                                <h3 class="card-title fw-bold text-white mb-2">@featuredGame.Title</h3>
                                <p class="card-text mt-3" style="color: #c4a6ff; font-size: 14px;">
                                    Featured game of the week. Don't miss the chance to add it to your library!
                                </p>
                                <div class="mt-auto pt-4 text-end pb-3">
                                    <span class="price-text me-3">
                                        @(featuredGame.Price == 0 ? "FREE" : featuredGame.Price.ToString("0.00") + " BGN")
                                    </span>
                                    <a asp-action="Details" asp-route-id="@featuredGame.Id" class="btn btn-purple fw-bold px-4">Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!hasFilters && isFirstPage)
            {
                <h4 class="fw-bold mb-3 mt-5 border-bottom border-secondary pb-2" style="color: #e6d9ff;">All Games</h4>
            }

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in displayGames)
                {
                    <div class="col">
                        <div class="card h-100 game-card shadow-sm border-0">

                            <div class="indicator-container">
                                @if (item.IsInWishlist)
                                {
                                    <div class="indicator-icon wishlist-active" title="In Wishlist">
                                        <i class="bi bi-heart-fill"></i>
                                    </div>
                                }
                                @if (item.IsInCart)
                                {
                                    <div class="indicator-icon cart-active" title="In Cart">
                                        <i class="bi bi-cart-check-fill"></i>
                                    </div>
                                }
                            </div>

                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@item.CoverImageUrl" class="game-card-img" alt="@item.Title">
                                }
                                else
                                {
                                    <div class="game-card-img bg-dark d-flex align-items-center justify-content-center">
                                        <i class="bi bi-image fs-1 text-secondary"></i>
                                    </div>
                                }
                            </a>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title fw-bold mb-1" style="color: #ffffff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.Title">
                                    @item.Title
                                </h6>

                                <div class="mb-2">
                                    @if (item.Platforms != null && item.Platforms.Any())
                                    {
                                        @foreach (var plt in item.Platforms.Take(3))
                                        {
                                            <span class="badge me-1 text-uppercase" style="background-color: #4a0080; font-size: 10px; border: 1px solid #8d00c4;">@plt</span>
                                        }
                                    }
                                </div>

                                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                                    @if (item.Price == 0)
                                    {
                                        <span class="price-text-sm text-success">FREE</span>
                                    }
                                    else
                                    {
                                        <span class="price-text-sm">@item.Price.ToString("0.00") BGN</span>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-purple fw-bold px-3">View</a>
                                </div>

                                @if (User.IsInRole("Admin"))
                                {
                                    <hr class="mt-3 mb-2" style="border-color: #4a0080;" />
                                    <div class="d-grid gap-1 d-md-flex justify-content-md-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning w-100" style="font-size: 12px; padding: 4px;">
                                            <i class="bi bi-pencil" style="color: white;"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100" style="font-size: 12px; padding: 4px;">
                                            <i class="bi bi-trash" style="color: white;"></i>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                int totalPages = ViewBag.TotalPages;
                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link page-link-dark fw-bold" asp-action="Index"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-searchQuery="@ViewBag.CurrentSearch"
                               asp-route-genre="@ViewBag.CurrentGenre"
                               asp-route-developerId="@ViewBag.CurrentDeveloperId"
                               asp-route-minPrice="@ViewBag.CurrentMinPrice"
                               asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                &laquo;
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link page-link-dark fw-bold" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchQuery="@ViewBag.CurrentSearch"
                                   asp-route-genre="@ViewBag.CurrentGenre"
                                   asp-route-developerId="@ViewBag.CurrentDeveloperId"
                                   asp-route-minPrice="@ViewBag.CurrentMinPrice"
                                   asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link page-link-dark fw-bold" asp-action="Index"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-searchQuery="@ViewBag.CurrentSearch"
                               asp-route-genre="@ViewBag.CurrentGenre"
                               asp-route-developerId="@ViewBag.CurrentDeveloperId"
                               asp-route-minPrice="@ViewBag.CurrentMinPrice"
                               asp-route-maxPrice="@ViewBag.CurrentMaxPrice">
                                &raquo;
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        let initialMinute = new Date().getMinutes();
        setInterval(function() {
            let currentMinute = new Date().getMinutes();
            if (currentMinute !== initialMinute) {
                window.location.reload();
            }
        }, 5000);
    </script>
}