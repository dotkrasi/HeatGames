@model HeatGames.Core.DTOs.GenreDto

@{
    ViewData["Title"] = "Edit Genre";
}

<style>
    .admin-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .admin-header {
        background-color: #1a0033;
        border-bottom: 2px solid #ffc107;
        border-radius: 8px 8px 0 0;
    }

    .admin-input {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .admin-input:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
        }

    .btn-warning-custom {
        background-color: #ffc107;
        color: #000000;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-warning-custom:hover {
            background-color: #ffcd39;
            color: #000000;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255, 193, 7, 0.4);
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="admin-card shadow-lg">
                <div class="admin-header p-4 d-flex align-items-center gap-3">
                    <i class="bi bi-pencil-square fs-3" style="color: #ffc107;"></i>
                    <h4 class="mb-0 text-white fw-bold">Edit Genre</h4>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-5">
                            <label asp-for="Name" class="form-label fw-bold"><i class="bi bi-fonts me-1 text-muted"></i> Genre Name</label>
                            <input asp-for="Name" class="form-control admin-input form-control-lg" />
                            <span asp-validation-for="Name" class="text-danger small fw-bold"></span>
                        </div>

                        <hr style="border-color: #4a0080;" class="my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Cancel</a>
                            <button type="submit" class="btn btn-warning-custom fw-bold px-4 py-2"><i class="bi bi-check-lg me-1"></i> Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}