@model IEnumerable<HeatGamesWeb.ViewModels.GameViewModel>

@{
    ViewData["Title"] = "Начало";

    // Взимаме 3 случайни игри за големия слайдер
    var sliderGames = Model.OrderBy(g => Guid.NewGuid()).Take(3).ToList();

    // Взимаме следващите 4 игри за секцията "Популярни"
    var trendingGames = Model.Skip(3).Take(4).ToList();
}

<style>
    /* Премахваме стандартните отстояния, за да изглежда по-широко */
    .home-wrapper {
        margin-top: -1.5rem;
        background-color: #0d121a; /* Класическо Steam тъмно синьо-черно */
        min-height: 100vh;
        padding-bottom: 50px;
    }

    /* STEAM СЛАЙДЪР */
    .steam-banner-section {
        background: linear-gradient(to bottom, #1b2838 0%, #0d121a 100%);
        padding: 40px 0;
        border-bottom: 1px solid #230046;
    }

    .slider-container {
        box-shadow: 0 10px 30px rgba(0,0,0,0.7);
        background: #0f161f;
        border-radius: 2px;
    }

    .slider-img {
        height: 400px;
        object-fit: cover;
    }

    .slider-info {
        background: #0f161f;
        padding: 30px;
        color: white;
    }

    .price-badge-steam {
        background-color: #4c6b22;
        color: #beee11;
        padding: 3px 10px;
        font-weight: bold;
        font-size: 1.2rem;
        display: inline-block;
        border-radius: 2px;
    }

    /* ЗАГЛАВИЯ НА СЕКЦИИ */
    .section-header {
        color: #ffffff;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 40px 0 20px 0;
        padding-left: 10px;
        border-left: 3px solid #be00ff;
    }

    /* МАЛКИ КАРТИ */
    .mini-game-card {
        background: #16202d;
        border: none;
        transition: transform 0.2s, background 0.2s;
        height: 100%;
    }

        .mini-game-card:hover {
            background: #1b2838;
            transform: scale(1.03);
        }

    .btn-buy-steam {
        background: linear-gradient(to right, #47bfff 0%, #1a44c2 100%);
        border: none;
        color: white;
        font-weight: bold;
        padding: 10px 20px;
        border-radius: 2px;
        text-decoration: none;
    }

        .btn-buy-steam:hover {
            background: linear-gradient(to right, #54c4ff 0%, #1e4bd6 100%);
            color: white;
        }

    .category-box {
        background: rgba(35, 0, 70, 0.4);
        border: 1px solid #4a0080;
        padding: 25px;
        text-align: center;
        border-radius: 4px;
        transition: 0.3s;
    }

        .category-box:hover {
            border-color: #be00ff;
            background: rgba(35, 0, 70, 0.6);
        }
</style>

<div class="home-wrapper">
    <section class="steam-banner-section">
        <div class="container">
            <h2 class="section-header">Препоръчано</h2>
            <div id="steamHomeCarousel" class="carousel slide slider-container overflow-hidden" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < sliderGames.Count; i++)
                    {
                        var game = sliderGames[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="row g-0">
                                <div class="col-md-8">
                                    <img src="@game.CoverImageUrl" class="slider-img w-100" alt="@game.Title">
                                </div>
                                <div class="col-md-4 slider-info d-flex flex-column justify-content-center">
                                    <h2 class="fw-bold mb-2">@game.Title</h2>
                                    <p class="text-muted small mb-4">Вземете я сега и се впуснете в приключението!</p>

                                    <div class="mb-4">
                                        <span class="price-badge-steam">
                                            @(game.Price == 0 ? "БЕЗПЛАТНО" : game.Price.ToString("0.00") + " лв.")
                                        </span>
                                    </div>

                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="btn btn-buy-steam align-self-start">РАЗГЛЕДАЙ</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#steamHomeCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#steamHomeCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </section>

    <div class="container mt-2">
        <h2 class="section-header">Популярни в момента</h2>
        <div class="row g-3">
            @foreach (var game in trendingGames)
            {
                <div class="col-md-3">
                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="text-decoration-none">
                        <div class="card mini-game-card">
                            <img src="@game.CoverImageUrl" class="card-img-top" style="height: 140px; object-fit: cover;">
                            <div class="card-body p-2">
                                <p class="text-white mb-1 small fw-bold text-truncate">@game.Title</p>
                                <p class="text-info mb-0 small">@game.Price.ToString("0.00") лв.</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <div class="row mt-5 g-4">
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-tags fs-1 text-primary mb-2 d-block"></i>
                    <h5 class="text-white">Разгледай по Жанр</h5>
                    <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-info mt-2">Към магазина</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-lightning-charge fs-1 text-warning mb-2 d-block"></i>
                    <h5 class="text-white">Нови заглавия</h5>
                    <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-info mt-2">Виж новото</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-percent fs-1 text-success mb-2 d-block"></i>
                    <h5 class="text-white">Специални цени</h5>
                    <a asp-controller="Games" asp-action="Index" asp-route-maxPrice="20" class="btn btn-sm btn-outline-info mt-2">Под 20 лв.</a>
                </div>
            </div>
        </div>
    </div>
</div>