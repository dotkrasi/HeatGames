@model IEnumerable<HeatGamesWeb.ViewModels.GameViewModel>

@{
    ViewData["Title"] = "Home";

    var sliderGames = Model.OrderBy(g => Guid.NewGuid()).Take(3).ToList();
    var trendingGames = Model.Skip(3).Take(4).ToList();

    var topDevelopers = ViewBag.TopDevelopers as List<HeatGames.Core.DTOs.DeveloperDto> ?? new List<HeatGames.Core.DTOs.DeveloperDto>();
}

<style>
    .home-wrapper {
        margin-top: -1.5rem;
        background-color: #000000;
        min-height: 100vh;
        padding-bottom: 50px;
    }

    .steam-banner-section {
        background: linear-gradient(to bottom, #1a0033 0%, #000000 100%);
        padding: 40px 0;
        border-bottom: 1px solid #4a0080;
    }

    .slider-container {
        box-shadow: 0 10px 30px rgba(190, 0, 255, 0.2);
        background: #230046;
        border-radius: 8px;
        border: 1px solid #4a0080;
    }

    .slider-img {
        height: 400px;
        object-fit: cover;
    }

    .slider-info {
        background: #230046;
        padding: 30px;
        color: white;
    }

    .price-badge-steam {
        background-color: transparent;
        color: #be00ff;
        padding: 3px 0;
        font-weight: bold;
        font-size: 1.5rem;
        display: inline-block;
    }

    .section-header {
        color: #e6d9ff;
        font-size: 16px;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 40px 0 20px 0;
        padding-left: 10px;
        border-left: 4px solid #be00ff;
        font-weight: bold;
    }

    .mini-game-card {
        background: #1a0033;
        border: 1px solid #4a0080;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
        height: 100%;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
    }

        .mini-game-card:hover {
            background: #230046;
            transform: translateY(-5px);
            border-color: #be00ff;
            box-shadow: 0 5px 15px rgba(190, 0, 255, 0.2);
        }

    .indicator-container {
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        gap: 8px;
        z-index: 10;
        pointer-events: none;
    }

    .indicator-icon {
        background-color: rgba(0, 0, 0, 0.7);
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .wishlist-active {
        color: #ff3366;
        border: 1px solid #ff3366;
        text-shadow: 0 0 8px #ff3366;
    }

    .cart-active {
        color: #BEEF52;
        border: 1px solid #BEEF52;
        text-shadow: 0 0 8px #BEEF52;
    }

    .btn-buy-steam {
        background-color: #8d00c4;
        border: none;
        color: white;
        font-weight: bold;
        padding: 10px 25px;
        border-radius: 4px;
        text-decoration: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-buy-steam:hover {
            background-color: #be00ff;
            color: white;
            transform: scale(1.02);
        }

    .category-box {
        background: #1a0033;
        border: 1px solid #4a0080;
        padding: 25px;
        text-align: center;
        border-radius: 8px;
        transition: 0.3s;
    }

        .category-box:hover {
            border-color: #be00ff;
            background: #230046;
            box-shadow: 0 5px 15px rgba(190, 0, 255, 0.15);
            transform: translateY(-3px);
        }

    .btn-outline-purple {
        color: #c4a6ff;
        border: 1px solid #4a0080;
        background-color: transparent;
        transition: 0.2s;
    }

        .btn-outline-purple:hover {
            background-color: #be00ff;
            border-color: #be00ff;
            color: white;
        }

    .developer-card {
        background: #1a0033;
        border: 1px solid #4a0080;
        border-radius: 8px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        transition: 0.3s;
    }

        .developer-card:hover {
            background: #230046;
            border-color: #be00ff;
            transform: scale(1.02);
            box-shadow: 0 0 15px rgba(190, 0, 255, 0.2);
        }

    .dev-logo-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        background: linear-gradient(135deg, #8d00c4, #4a0080);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        font-weight: bold;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
    }
</style>

<div class="home-wrapper">
    <section class="steam-banner-section">
        <div class="container">
            <h2 class="section-header">Recommended For You</h2>
            <div id="steamHomeCarousel" class="carousel slide slider-container overflow-hidden" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < sliderGames.Count; i++)
                    {
                        var game = sliderGames[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="row g-0">
                                <div class="col-md-8">
                                    <img src="@game.CoverImageUrl" class="slider-img w-100" alt="@game.Title">
                                </div>
                                <div class="col-md-4 slider-info d-flex flex-column justify-content-center">
                                    <h2 class="fw-bold mb-2 text-white">@game.Title</h2>
                                    <p class="mb-4" style="color: #c4a6ff; font-size: 0.95rem;">Discover new worlds and embark on an adventure. Available now on HeatGames!</p>

                                    <div class="mb-4 mt-auto">
                                        <span class="price-badge-steam">
                                            @(game.Price == 0 ? "FREE" : game.Price.ToString("0.00") + " BGN")
                                        </span>
                                    </div>

                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="btn btn-buy-steam align-self-start">VIEW DETAILS</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#steamHomeCarousel" data-bs-slide="prev" style="width: 5%;">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#steamHomeCarousel" data-bs-slide="next" style="width: 5%;">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </section>

    <div class="container mt-4">
        <h2 class="section-header">Trending Now</h2>
        <div class="row g-4">
            @foreach (var game in trendingGames)
            {
                <div class="col-md-3">
                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="text-decoration-none">
                        <div class="card mini-game-card">

                            <div class="indicator-container">
                                @if (game.IsInWishlist)
                                {
                                    <div class="indicator-icon wishlist-active" title="In Wishlist">
                                        <i class="bi bi-heart-fill"></i>
                                    </div>
                                }
                                @if (game.IsInCart)
                                {
                                    <div class="indicator-icon cart-active" title="In Cart">
                                        <i class="bi bi-cart-check-fill"></i>
                                    </div>
                                }
                            </div>

                            <img src="@game.CoverImageUrl" class="card-img-top" style="height: 160px; object-fit: cover;">
                            <div class="card-body p-3 d-flex flex-column">
                                <p class="text-white mb-0 fw-bold text-truncate" title="@game.Title">@game.Title</p>
                                <p class="mb-2 text-truncate" style="font-size: 0.8rem; color: #acb1b8;">By: <span style="color: #00d2ff;">@game.DeveloperName</span></p>

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span style="color: #be00ff; font-weight: bold; font-size: 1.1rem;">
                                        @(game.Price == 0 ? "FREE" : game.Price.ToString("0.00") + " BGN")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (topDevelopers.Any())
        {
            <h2 class="section-header mt-5">Featured Studios</h2>
            <div class="row g-4">
                @foreach (var dev in topDevelopers)
                {
                    <div class="col-md-4">
                        <a asp-controller="Games" asp-action="Index" asp-route-developerId="@dev.Id" class="developer-card shadow-sm">
                            <div class="dev-logo-placeholder">
                                @(string.IsNullOrEmpty(dev.Name) ? "D" : dev.Name.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1 m-0">@dev.Name</h5>
                                <span style="color: #acb1b8; font-size: 0.85rem;"><i class="bi bi-controller me-1"></i> Browse their games</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        <h2 class="section-header mt-5">Browse By Category</h2>
        <div class="row g-4 pb-4">
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-controller fs-1 mb-3 d-block" style="color: #be00ff;"></i>
                    <h5 class="text-white fw-bold">Explore Catalog</h5>
                    <p style="color: #c4a6ff; font-size: 0.9rem;">Find your next favorite game among dozens of titles.</p>
                    <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-purple mt-2 px-4">Go to Store</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-star-fill fs-1 mb-3 d-block" style="color: #be00ff;"></i>
                    <h5 class="text-white fw-bold">Top Games Under 50 BGN</h5>
                    <p style="color: #c4a6ff; font-size: 0.9rem;">Great titles at affordable prices. Don't miss out!</p>
                    <a asp-controller="Games" asp-action="Index" asp-route-maxPrice="50" class="btn btn-sm btn-outline-purple mt-2 px-4">View Deals</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="category-box">
                    <i class="bi bi-gift-fill fs-1 mb-3 d-block" style="color: #be00ff;"></i>
                    <h5 class="text-white fw-bold">Free Adventures</h5>
                    <p style="color: #c4a6ff; font-size: 0.9rem;">Play right away without spending a single dime.</p>
                    <a asp-controller="Games" asp-action="Index" asp-route-maxPrice="0" class="btn btn-sm btn-outline-purple mt-2 px-4">Play for Free</a>
                </div>
            </div>
        </div>
    </div>
</div>