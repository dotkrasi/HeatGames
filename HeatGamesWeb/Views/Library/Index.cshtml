@model IEnumerable<HeatGames.Core.DTOs.LibraryItemDto>

@{
    ViewData["Title"] = "My Library";
}

<style>
    .library-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        color: #e6d9ff;
        overflow: hidden;
    }

        .library-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(190, 0, 255, 0.3);
            border-color: #be00ff;
        }

    .empty-library {
        background-color: #1a0033;
        border: 1px dashed #4a0080;
        border-radius: 8px;
        color: #c4a6ff;
    }

    .btn-magenta {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }

    .btn-play {
        background-color: #BEEF52;
        color: #000000;
        border: none;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: 0.2s;
    }

        .btn-play:hover {
            background-color: #ffffff;
            transform: scale(1.03);
            box-shadow: 0 0 15px rgba(190, 239, 82, 0.8);
        }

    .btn-stop {
        background-color: #dc3545;
        color: #ffffff;
        border: none;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: 0.2s;
    }

        .btn-stop:hover {
            background-color: #ff4d4d;
            transform: scale(1.03);
            box-shadow: 0 0 15px rgba(220, 53, 69, 0.8);
        }

    .btn-download {
        background-color: transparent;
        color: #c4a6ff;
        border: 1px dashed #be00ff;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.2s;
    }

        .btn-download:hover {
            background-color: rgba(190, 0, 255, 0.1);
            color: #ffffff;
            border-style: solid;
        }

    .game-stats {
        color: #c4a6ff;
        font-size: 0.85rem;
    }

    .playing-pulse {
        animation: pulse 1.5s infinite;
        color: #BEEF52 !important;
        text-shadow: 0 0 8px #BEEF52;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4 pb-3" style="border-bottom: 2px solid #4a0080;">
        <div>
            <h2 class="fw-bold m-0 text-white"><i class="bi bi-collection-play-fill" style="color: #be00ff;"></i> Game Library</h2>
        </div>
        <div>
            <span class="badge" style="background-color: #4a0080; font-size: 1rem; padding: 8px 15px;">
                @(Model?.Count() ?? 0) Titles
            </span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-library text-center p-5 shadow-lg">
            <i class="bi bi-controller mb-3" style="font-size: 4rem; color: #4a0080;"></i>
            <h4 class="text-white fw-bold mt-2">Your library is empty</h4>
            <p class="mb-4">Time for new adventures!</p>
            <a asp-controller="Games" asp-action="Index" class="btn btn-magenta px-4 py-2">Go to Store</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 library-card shadow-sm border-0">
                        @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                        {
                            <img src="@item.CoverImageUrl" class="card-img-top" alt="@item.GameTitle" style="height: 220px; object-fit: cover;">
                        }

                        <div class="card-body d-flex flex-column text-center p-3">
                            <h6 class="card-title fw-bold text-white mb-3">@item.GameTitle</h6>

                            <div class="mb-3 game-stats">
                                <p class="mb-1"><i class="bi bi-calendar-check"></i> Purchased: @item.PurchaseDate.ToString("dd.MM.yyyy")</p>
                                <p class="mb-0 text-info fw-bold time-display" id="time-@item.Id" style="color: #be00ff !important;">
                                    <i class="bi bi-clock-history"></i> Playtime: <span id="minutes-@item.Id">@item.PlayTimeMinutes</span> min
                                </p>
                            </div>

                            <div class="mt-auto d-flex flex-column gap-2 action-container" id="actions-@item.Id">
                                <a asp-controller="Library" asp-action="Download" asp-route-gameId="@item.GameId" class="btn btn-download w-100 py-2 shadow-sm download-btn" data-id="@item.Id">
                                    <i class="bi bi-cloud-arrow-down-fill me-1 fs-5"></i> DOWNLOAD
                                </a>

                                <button class="btn btn-play w-100 py-2 shadow-sm play-btn d-none" data-id="@item.Id" id="btn-@item.Id">
                                    <i class="bi bi-play-fill fs-5 me-1" id="icon-@item.Id"></i> <span id="text-@item.Id">PLAY</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 1. ЛОГИКА ЗА СВАЛЯНЕ (DOWNLOAD -> PLAY)
            const actionContainers = document.querySelectorAll('.action-container');
            actionContainers.forEach(container => {
                const libraryId = container.id.replace('actions-', '');
                const downloadBtn = container.querySelector('.download-btn');
                const playBtn = container.querySelector('.play-btn');

                // Проверяваме дали вече сме я "свалили" (гледаме в паметта на браузъра)
                if (localStorage.getItem('downloaded_' + libraryId) === 'true') {
                    downloadBtn.classList.add('d-none'); // Скриваме Download
                    playBtn.classList.remove('d-none');  // Показваме Play
                }

                // Когато потребителят кликне DOWNLOAD
                if (downloadBtn) {
                    downloadBtn.addEventListener('click', function (e) {
                        // Записваме в паметта, че е свалена
                        localStorage.setItem('downloaded_' + libraryId, 'true');

                        // Сменяме бутоните след 1 секунда (за да създадем усещане, че нещо се случва)
                        setTimeout(() => {
                            downloadBtn.classList.add('d-none');
                            playBtn.classList.remove('d-none');
                        }, 1000);
                    });
                }
            });

            // 2. ЛОГИКА ЗА ИГРАЕНЕ И ТАЙМЕР (Запазена на 100%)
            const playButtons = document.querySelectorAll('.play-btn');
            playButtons.forEach(btn => {
                let intervalId = null;
                let addedMinutes = 0;

                btn.addEventListener('click', function () {
                    const libraryId = this.getAttribute('data-id');
                    const textSpan = document.getElementById(`text-${libraryId}`);
                    const icon = document.getElementById(`icon-${libraryId}`);
                    const minutesSpan = document.getElementById(`minutes-${libraryId}`);
                    const timeDisplay = document.getElementById(`time-${libraryId}`);

                    let currentTotalMinutes = parseInt(minutesSpan.innerText);

                    // ПУСКАМЕ ИГРАТА
                    if (!this.classList.contains('btn-stop')) {
                        this.classList.remove('btn-play');
                        this.classList.add('btn-stop');
                        textSpan.innerText = 'STOP';
                        icon.classList.remove('bi-play-fill');
                        icon.classList.add('bi-stop-fill');

                        timeDisplay.classList.add('playing-pulse');
                        addedMinutes = 0;

                        intervalId = setInterval(() => {
                            addedMinutes++;
                            minutesSpan.innerText = currentTotalMinutes + addedMinutes;
                        }, 1000);
                    }
                    // СПИРАМЕ ИГРАТА
                    else {
                        this.classList.remove('btn-stop');
                        this.classList.add('btn-play');
                        textSpan.innerText = 'PLAY';
                        icon.classList.remove('bi-stop-fill');
                        icon.classList.add('bi-play-fill');

                        timeDisplay.classList.remove('playing-pulse');
                        clearInterval(intervalId);

                        if (addedMinutes > 0) {
                            fetch('/Library/SavePlayTime', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ libraryItemId: libraryId, minutesToAdd: addedMinutes })
                            })
                            .then(response => {
                                if(response.ok) {
                                    console.log(`Successfully added ${addedMinutes} minutes to library item ${libraryId}`);
                                }
                            });
                        }
                    }
                });
            });
        });
    </script>
}