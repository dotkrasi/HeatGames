@model IEnumerable<HeatGames.Core.DTOs.LibraryItemDto>

@{
    ViewData["Title"] = "Моята Библиотека";
}

<h2 class="mt-4 mb-4 fw-bold"><i class="bi bi-collection-play"></i> Библиотека с игри</h2>

@if (!Model.Any())
{
    <div class="alert alert-secondary text-center p-5 shadow-sm rounded-lg">
        <i class="bi bi-controller" style="font-size: 3rem;"></i>
        <h4 class="mt-3">Библиотеката ви е празна</h4>
        <p>Все още не сте закупили нито една игра.</p>
        <a asp-controller="Games" asp-action="Index" class="btn btn-primary mt-2">Към Магазина</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm bg-dark text-white border-0">
                    @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                    {
                        <img src="@item.CoverImageUrl" class="card-img-top" alt="@item.GameTitle" style="height: 200px; object-fit: cover; opacity: 0.9;">
                    }
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">@item.GameTitle</h5>
                        <p class="text-muted small mb-0">Купена на: @item.PurchaseDate.ToString("dd.MM.yyyy")</p>
                        <p class="text-info small"><i class="bi bi-clock"></i> Изиграно: @item.PlayTimeMinutes мин.</p>
                        <button class="btn btn-outline-light btn-sm mt-2 w-100"><i class="bi bi-play-fill"></i> ИГРАЙ</button>
                    </div>
                </div>
            </div>
        }
    </div>
}