@model IEnumerable<HeatGames.Core.DTOs.OrderDto>

@{
    ViewData["Title"] = "Order History";
}

<style>
    .history-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
        padding: 20px;
    }

    .table-dark-purple {
        color: #e6d9ff;
        background-color: transparent;
        border-color: #4a0080;
    }

        .table-dark-purple th {
            border-bottom: 2px solid #8d00c4;
            color: #c4a6ff;
            text-transform: uppercase;
            letter-spacing: 1px;
            background-color: transparent;
        }

        .table-dark-purple td {
            border-bottom: 1px solid #4a0080;
            vertical-align: middle;
            background-color: transparent;
            color: #e6d9ff;
        }

        .table-dark-purple tbody tr:hover td,
        .table-dark-purple tbody tr:hover th {
            background-color: #1a0033 !important;
            color: #ffffff !important;
        }

            .table-dark-purple tbody tr:hover td .text-muted {
                color: #d1d5db !important;
            }

            .table-dark-purple tbody tr:hover td .text-success {
                color: #198754 !important;
            }
</style>

<div class="container mt-5 mb-5">
    <h2 class="mb-4 fw-bold" style="color: #e6d9ff;">
        <i class="bi bi-receipt" style="color: #be00ff;"></i> Order History
    </h2>

    @if (!Model.Any())
    {
        <div class="alert text-center shadow-sm" style="background-color: #1a0033; border: 1px dashed #4a0080; color: #c4a6ff;">
            <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
            You have no orders yet.
        </div>
    }
    else
    {
        <div class="history-card shadow-lg">
            <div class="table-responsive rounded">
                <table class="table table-dark-purple table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th class="text-end">Total Paid</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="text-muted small align-middle" style="font-family: monospace;">@order.Id.ToString().Substring(0, 8)...</td>
                                <td class="align-middle">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="align-middle">
                                    <ul class="list-unstyled mb-0">
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <li>
                                                <i class="bi bi-controller me-1" style="color: #c4a6ff;"></i>
                                                <strong>@item.GameTitle</strong>
                                                <span class="text-muted">(@item.PriceAtPurchase.ToString("0.00") BGN)</span>
                                            </li>
                                        }
                                    </ul>
                                </td>
                                <td class="text-end align-middle fw-bold text-success fs-5">@order.TotalAmount.ToString("0.00") BGN</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>