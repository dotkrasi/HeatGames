@model HeatGames.Core.DTOs.PlatformDto
@{
    ViewData["Title"] = "Изтриване на жанр";
}

<style>
    .admin-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
        color: #e6d9ff;
    }

    .admin-header-danger {
        background-color: #1a0033;
        border-bottom: 2px solid #dc3545;
        border-radius: 8px 8px 0 0;
    }

    .btn-danger-custom {
        background-color: #dc3545;
        color: #ffffff;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-danger-custom:hover {
            background-color: #ff4d4d;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(220, 53, 69, 0.4);
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="admin-card shadow-lg">
                <div class="admin-header-danger p-4 d-flex align-items-center gap-3">
                    <i class="bi bi-exclamation-triangle-fill fs-3 text-danger"></i>
                    <h4 class="mb-0 text-white fw-bold">Потвърждение за изтриване</h4>
                </div>

                <div class="card-body p-4 p-md-5 text-center">
                    <h5 class="mb-4" style="color: #c4a6ff;">Сигурни ли сте, че искате да изтриете този жанр?</h5>

                    <div class="p-4 mb-4 rounded shadow-sm" style="background-color: #1a0033; border: 1px dashed #dc3545;">
                        <h2 class="fw-bold text-white m-0">@Model.Name</h2>
                    </div>

                    <div class="alert alert-danger fw-bold mb-5" style="background-color: #4d0000; color: #ffcccc; border: none;">
                        <i class="bi bi-info-circle-fill"></i> Внимание: Това действие е необратимо!
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <hr style="border-color: #4a0080;" class="my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Отказ</a>
                            <button type="submit" class="btn btn-danger-custom fw-bold px-4 py-2">
                                <i class="bi bi-trash-fill me-1"></i> Да, Изтрий
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>