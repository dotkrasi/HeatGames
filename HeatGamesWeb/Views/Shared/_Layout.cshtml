@using Microsoft.AspNetCore.Identity
@using HeatGames.Data.Models
@using Microsoft.AspNetCore.Http
@using HeatGamesWeb.Extensions
@using HeatGamesWeb.ViewModels
@inject UserManager<User> UserManager
@inject IHttpContextAccessor HttpContextAccessor

@{
    User currentUser = null;
    if (User.Identity?.IsAuthenticated ?? false)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    var sessionCart = HttpContextAccessor.HttpContext?.Session.Get<List<CartItemViewModel>>("ShoppingCart");
    int cartCount = sessionCart?.Count ?? 0;
}

<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeatGames</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeatGamesWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        .steam-dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0 !important;
        }

        .steam-dropdown-menu {
            background-color: #230046;
            border: 1px solid #4a0080;
            border-radius: 0;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.8);
        }

            .steam-dropdown-menu .dropdown-item {
                color: #e6d9ff;
                font-size: 13px;
                padding: 8px 20px;
                transition: all 0.2s ease-in-out;
            }

                .steam-dropdown-menu .dropdown-item:hover {
                    background-color: #8d00c4 !important;
                    color: #ffffff !important;
                    text-decoration: none !important;
                }

        .dropdown-menu-end {
            right: 0 !important;
            left: auto !important;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #000000;
            color: #e6d9ff;
            font-family: "Motiva Sans", Sans-serif;
            display: flex;
            flex-direction: column;
        }

        .main-content-wrapper {
            flex: 1 0 auto;
        }

        .site-footer {
            flex-shrink: 0;
        }

        .steam-navbar {
            background-color: #000000;
            border-bottom: 2px solid #230046;
        }

        .steam-nav-link {
            color: #c4a6ff !important;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            padding: 10px 15px !important;
            transition: color 0.2s;
        }

            .steam-nav-link:hover, .steam-nav-link.active {
                color: #be00ff !important;
            }

        .steam-profile-btn {
            background-color: #000000;
            color: #e6d9ff;
            border: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .steam-profile-btn:hover {
                color: #ffffff;
            }

        .cart-icon-container {
            color: #e6d9ff;
            transition: all 0.2s ease-in-out;
            position: relative;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

            .cart-icon-container:hover {
                color: #be00ff !important;
                transform: scale(1.1);
            }

        .cart-badge {
            background-color: #be00ff;
            color: #ffffff;
            font-size: 0.65rem;
            font-weight: bold;
            padding: 3px 6px;
            border-radius: 50%;
            position: absolute;
            top: -5px;
            right: -12px;
            border: 2px solid #000000;
            box-shadow: 0 0 8px rgba(190, 0, 255, 0.6);
        }

        body a {
            transition: color 0.1s ease-in-out !important;
        }

            body a:hover {
                color: #ffffff !important;
                text-decoration: none !important;
            }

        .table-responsive a, .text-info a {
            color: #00d2ff !important;
        }

            .table-responsive a:hover, .text-info a:hover {
                color: #ffffff !important;
            }

        .text-success:hover, .text-danger:hover, .text-warning:hover, .text-primary:hover {
            color: #ffffff !important;
        }
    </style>
</head>
<body class="d-flex flex-column h-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark steam-navbar py-2 shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-controller fs-3"></i> HeatGames
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">

                        <li class="nav-item">
                            <a class="nav-link steam-nav-link" asp-area="" asp-controller="Home" asp-action="Index">HOME</a>
                        </li>

                        <li class="nav-item dropdown steam-dropdown">
                            <a class="nav-link steam-nav-link" asp-controller="Games" asp-action="Index">STORE</a>
                            <ul class="dropdown-menu steam-dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Games" asp-action="Index">All Games</a></li>
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <li><a class="dropdown-item" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart"></i> Wishlist</a></li>
                                }
                            </ul>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown steam-dropdown">
                                <a class="nav-link steam-nav-link" asp-controller="Library" asp-action="Index">LIBRARY</a>
                                <ul class="dropdown-menu steam-dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Library" asp-action="Index">🎮 My Library</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">🧾 Order History</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown steam-dropdown ms-3">
                                <a class="nav-link steam-nav-link text-warning" href="#">ADMIN</a>
                                <ul class="dropdown-menu steam-dropdown-menu border border-warning">
                                    <li><a class="dropdown-item" asp-controller="Developer" asp-action="Index">Developers</a></li>
                                    <li><a class="dropdown-item" asp-controller="Genre" asp-action="Index">Genres</a></li>
                                    <li><a class="dropdown-item" asp-controller="Platform" asp-action="Index">Platforms</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Manage">Orders</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item ms-2 me-4">
                                <a asp-controller="Cart" asp-action="Index" class="cart-icon-container" title="My Cart">
                                    <i class="bi bi-cart3 fs-4"></i>
                                    @if (cartCount > 0)
                                    {
                                        <span class="cart-badge">@cartCount</span>
                                    }
                                </a>
                            </li>

                            <li class="nav-item dropdown steam-dropdown">
                                <button class="steam-profile-btn" type="button">
                                    <img src="@(currentUser?.ProfilePictureUrl ?? "https://avatars.steamstatic.com/fef49e7fa7e1997310d705b2a6158ff8dc1cdfeb_full.jpg")" alt="Avatar" width="32" height="32" class="rounded-1" style="object-fit: cover;">
                                    <div class="d-flex flex-column text-start" style="line-height: 1;">
                                        <span style="font-size: 13px; font-weight: bold; color: #5d5462;">@User.Identity.Name <i class="bi bi-chevron-down ms-1" style="font-size: 10px;"></i></span>
                                        <span style="font-size: 11px; color: #acb1b8;">@(currentUser?.WalletBalance.ToString("0.00") ?? "0.00") лв.</span>
                                    </div>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end steam-dropdown-menu mt-2">
                                    <li>
                                        <a class="dropdown-item fw-bold" asp-controller="User" asp-action="Index" style="color: #c4a6ff;">
                                            <i class="bi bi-person-fill me-2"></i>My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item fw-bold" asp-controller="Wallet" asp-action="Index" style="color: #2bd45f;">
                                            <i class="bi bi-wallet2 me-2"></i> Wallet
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider bg-secondary"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item fw-bold" style="color: #ff4d4d; border: none; background: transparent; width: 100%; text-align: left;">
                                                Sign out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-sm btn-success text-white px-3 fw-bold ms-2" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="main-content-wrapper flex-shrink-0">
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="site-footer mt-auto pt-5 pb-3 shadow-lg" style="background-color: #090014; border-top: 2px solid #230046;">
        <div class="container">
            <div class="row gy-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="text-white fw-bold mb-3 d-flex align-items-center gap-2">
                        <i class="bi bi-controller fs-4" style="color: #be00ff;"></i> HeatGames
                    </h5>
                    <p style="color: #acb1b8; font-size: 0.95rem; line-height: 1.6;">
                        Your ultimate destination for digital gaming. Discover new worlds, conquer epic quests, and build your dream library with the best titles in the universe.
                    </p>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Explore</h6>
                    <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                        <li><a asp-controller="Home" asp-action="Index" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Home</a></li>
                        <li><a asp-controller="Games" asp-action="Index" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Store</a></li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li><a asp-controller="Library" asp-action="Index" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">My Library</a></li>
                            <li><a asp-controller="Wishlist" asp-action="Index" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Wishlist</a></li>
                        }
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Support</h6>
                    <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                        <li>
                            <a asp-controller="Home" asp-action="Faq" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">FAQ</a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="RefundPolicy" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Refund Policy</a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="Privacy" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Privacy Policy</a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="TermsOfService" style="color: #c4a6ff; text-decoration: none; transition: 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#c4a6ff'">Terms of Service</a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Join The Community</h6>
                    <div class="d-flex gap-3">
                        <a href="https://discord.com/" class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #230046; color: #e6d9ff; text-decoration: none; transition: 0.3s;" onmouseover="this.style.backgroundColor='#be00ff'; this.style.color='#fff'" onmouseout="this.style.backgroundColor='#230046'; this.style.color='#e6d9ff'">
                            <i class="bi bi-discord fs-5"></i>
                        </a>
                        <a href="https://x.com/azis_online" class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #230046; color: #e6d9ff; text-decoration: none; transition: 0.3s;" onmouseover="this.style.backgroundColor='#be00ff'; this.style.color='#fff'" onmouseout="this.style.backgroundColor='#230046'; this.style.color='#e6d9ff'">
                            <i class="bi bi-twitter-x fs-5"></i>
                        </a>
                        <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #230046; color: #e6d9ff; text-decoration: none; transition: 0.3s;" onmouseover="this.style.backgroundColor='#be00ff'; this.style.color='#fff'" onmouseout="this.style.backgroundColor='#230046'; this.style.color='#e6d9ff'">
                            <i class="bi bi-youtube fs-5"></i>
                        </a>
                        <a href="https://www.twitch.tv/aethelthryth" class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #230046; color: #e6d9ff; text-decoration: none; transition: 0.3s;" onmouseover="this.style.backgroundColor='#be00ff'; this.style.color='#fff'" onmouseout="this.style.backgroundColor='#230046'; this.style.color='#e6d9ff'">
                            <i class="bi bi-twitch fs-5"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="text-center pt-4" style="border-top: 1px solid #230046;">
                <p style="color: #6b5a82; font-size: 0.85rem; margin: 0;">
                    &copy; 2026 HeatGames. All rights reserved. Trademarks belong to their respective owners.
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>