@using Microsoft.AspNetCore.Identity
@using HeatGames.Data.Models
@inject UserManager<User> UserManager

@{
    // Взимаме текущия логнат потребител, за да му покажем баланса горе вдясно
    User currentUser = null;
    if (User.Identity?.IsAuthenticated ?? false)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeatGamesWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeatGamesWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        /* ПОДРАВНЕН И ПОЛИРАН ДИЗАЙН ЗА ПРОФИЛНОТО МЕНЮ */
        .steam-dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0 !important;
        }

        .steam-dropdown-menu {
            background-color: #230046;
            border: 1px solid #4a0080;
            border-radius: 0;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.8);
        }

            .steam-dropdown-menu .dropdown-item {
                color: #e6d9ff;
                font-size: 13px;
                padding: 8px 20px;
            }

                .steam-dropdown-menu .dropdown-item:hover {
                    background-color: #4a0080;
                    color: #ffffff;
                }

        /* Принудително подравняване вдясно за профилното меню (за да не излиза от екрана) */
        .dropdown-menu-end {
            right: 0 !important;
            left: auto !important;
        }
        /* ЛИЛАВА ПАЛЕТА ОТ СНИМКАТА */
        body {
            background-color: #000000; /* 1. Чисто ЧЕРНО за основен фон */
            color: #e6d9ff; /* Леко лилав оттенък на бялото за текст */
            font-family: "Motiva Sans", Sans-serif;
        }

        .steam-navbar {
            background-color: #000000;
            border-bottom: 2px solid #230046; /* 2. Тъмно лилава линия */
        }

        .steam-nav-link {
            color: #c4a6ff !important;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            padding: 10px 15px !important;
            transition: color 0.2s;
        }

            /* Hover ефект */
            .steam-nav-link:hover, .steam-nav-link.active {
                color: #be00ff !important; /* 5. Най-яркото лилаво (Магента) */
            }

        /* ПАДАЩИ МЕНЮТА ПРИ HOVER */
        .steam-dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0 !important;
        }

        .steam-dropdown-menu {
            background-color: #230046; /* 2. Тъмно лилаво за менютата */
            border: 1px solid #4a0080; /* 3. Средно лилаво за рамка */
            border-radius: 0;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.8);
        }

            .steam-dropdown-menu .dropdown-item {
                color: #e6d9ff;
                font-size: 13px;
                padding: 8px 20px;
            }

                .steam-dropdown-menu .dropdown-item:hover {
                    background-color: #4a0080; /* 3. Средно лилаво при посочване */
                    color: #ffffff;
                }

        /* Стил за профила горе вдясно */
        .steam-profile-btn {
            background-color: #000000;
            color: #e6d9ff;
            border: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .steam-profile-btn:hover {
                color: #ffffff;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark steam-navbar py-2 shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-controller fs-3"></i> HeatGamesWeb
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">

                        <li class="nav-item">
                            <a class="nav-link steam-nav-link" asp-area="" asp-controller="Home" asp-action="Index">HOME</a>
                        </li>

                        <li class="nav-item dropdown steam-dropdown">
                            <a class="nav-link steam-nav-link" asp-controller="Games" asp-action="Index">STORE</a>
                            <ul class="dropdown-menu steam-dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Games" asp-action="Index">Всички игри</a></li>
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <li><a class="dropdown-item" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart"></i> Списък с желания</a></li>
                                }
                            </ul>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown steam-dropdown">
                                <a class="nav-link steam-nav-link" asp-controller="Library" asp-action="Index">LIBRARY</a>
                                <ul class="dropdown-menu steam-dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Library" asp-action="Index">🎮 Моята Библиотека</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">🧾 История на поръчките</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown steam-dropdown ms-3">
                                <a class="nav-link steam-nav-link text-warning" href="#">ADMIN</a>
                                <ul class="dropdown-menu steam-dropdown-menu border border-warning">
                                    <li><a class="dropdown-item" asp-controller="Developer" asp-action="Index">Developers</a></li>
                                    <li><a class="dropdown-item" asp-controller="Genre" asp-action="Index">Genres</a></li>
                                    <li><a class="dropdown-item" asp-controller="Games" asp-action="Create">Add New Game</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    @* ——— ТОВА БЕШЕ БЛОКЪТ ЗА ПРОФИЛА. ВЕЧЕ Е ОБНОВЕН С ЛИНКА И СНИМКАТА! ——— *@
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown steam-dropdown ms-2">
                                <button class="steam-profile-btn" type="button">
                                    <img src="@(currentUser?.ProfilePictureUrl ?? "https://avatars.steamstatic.com/fef49e7fa7e1997310d705b2a6158ff8dc1cdfeb_full.jpg")" alt="Avatar" width="32" height="32" class="rounded-1" style="object-fit: cover;">
                                    <div class="d-flex flex-column text-start" style="line-height: 1;">
                                        <span style="font-size: 13px; font-weight: bold; color: #5d5462;">@User.Identity.Name <i class="bi bi-chevron-down ms-1" style="font-size: 10px;"></i></span>
                                        <span style="font-size: 11px; color: #acb1b8;">@(currentUser?.WalletBalance.ToString("0.00") ?? "0.00") лв.</span>
                                    </div>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end steam-dropdown-menu">
                                    <li><a class="dropdown-item text-white fw-bold" asp-controller="User" asp-action="Index"><i class="bi bi-person-fill me-2" style="color: #be00ff;"></i>Моят Профил</a></li>
                                    <li><a class="dropdown-item text-success fw-bold" asp-controller="Wallet" asp-action="Index"><i class="bi bi-wallet2"></i> Портфейл</a></li>
                                    <li><hr class="dropdown-divider bg-secondary"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item text-danger">Sign out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Account" asp-action="Register">Регистрация</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-sm btn-success text-white px-3 fw-bold ms-2" asp-controller="Account" asp-action="Login">Вход</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 pt-3 pb-3" style="border-color: #3b3641 !important;">
        <div class="container text-center">
            &copy; 2026 - HeatGamesWeb - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: #5d5462;">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>