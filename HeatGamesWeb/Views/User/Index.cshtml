@model HeatGames.Core.DTOs.UserProfileDto
@{
    ViewData["Title"] = "Моят Профил";
}

<style>
    .profile-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 12px;
        color: #e6d9ff;
    }

    .profile-img-container {
        width: 150px;
        height: 150px;
        border: 4px solid #be00ff;
        border-radius: 50%;
        overflow: hidden;
        margin: 0 auto;
        box-shadow: 0 0 20px rgba(190, 0, 255, 0.4);
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .admin-input {
        background-color: #000000;
        color: #e6d9ff;
        border: 1px solid #4a0080;
    }

        .admin-input[readonly] {
            background-color: #000000 !important;
            color: #acb1b8 !important;
            opacity: 1;
        }

        .admin-input:focus {
            background-color: #1a0033;
            color: #ffffff;
            border-color: #be00ff;
        }
</style>

<div class="container mt-5 mb-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" style="background-color: #4d0000; color: #ffcccc; border: 1px solid #ff0000;" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> <strong>Грешка!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;" role="alert">
            <i class="bi bi-check-circle-fill"></i> <strong>Успех!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="profile-card shadow-lg p-5">
                <div class="text-center mb-5">
                    <div class="profile-img-container mb-3">
                        <img src="@(Model.ProfilePictureUrl ?? "https://avatars.steamstatic.com/fef49e7fa7e1997310d705b2a6158ff8dc1cdfeb_full.jpg")" class="profile-img" alt="Avatar" />
                    </div>
                    <h2 class="fw-bold text-white">@Model.Username</h2>
                    <span class="badge" style="background-color: #4a0080;">Член от: @Model.RegistrationDate.ToString("MMMM yyyy")</span>
                </div>

                <form asp-action="Update" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Username" />
                    <input type="hidden" asp-for="RegistrationDate" />
                    <input type="hidden" asp-for="WalletBalance" />

                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold">Имейл</label>
                            <input asp-for="Email" class="form-control admin-input" readonly />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold">Баланс в портфейла</label>
                            <div class="form-control admin-input border-0" style="color: #BEEF52; font-weight: 900;">
                                @Model.WalletBalance.ToString("0.00") лв.
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ProfilePictureUrl" class="form-label fw-bold"></label>
                        <input asp-for="ProfilePictureUrl" class="form-control admin-input" placeholder="https://..." />
                    </div>

                    <hr class="my-5" style="border-color: #4a0080;">
                    <h4 class="mb-4 text-white"><i class="bi bi-shield-lock me-2" style="color: #be00ff;"></i>Смяна на парола</h4>

                    <div class="mb-4">
                        <label asp-for="CurrentPassword" class="form-label text-muted"></label>
                        <input asp-for="CurrentPassword" class="form-control admin-input" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label text-muted"></label>
                        <input asp-for="NewPassword" class="form-control admin-input" />
                        <span asp-validation-for="NewPassword" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-lg px-5 fw-bold" style="background-color: #be00ff; color: white;">ЗАПАЗИ ПРОМЕНИТЕ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>