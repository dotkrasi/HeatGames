@model decimal

@{
    ViewData["Title"] = "Моят Портфейл";
}

<style>
    /* ТЪМНО-ЛИЛАВ СТИЛ ЗА ПОРТФЕЙЛА */
    .wallet-card {
        background-color: #230046;
        border: 1px solid #4a0080;
        border-radius: 8px;
    }

    .wallet-balance-text {
        color: #BEEF52; /* Steam Зелено за парите */
        text-shadow: 0 0 10px rgba(190, 239, 82, 0.2);
    }

    .fund-list-item {
        background-color: #1a0033; /* По-тъмно лилаво за списъка */
        border: 1px solid #4a0080;
        color: #e6d9ff;
        transition: 0.2s;
    }

        .fund-list-item:hover {
            background-color: #230046;
            border-color: #be00ff;
        }

    .btn-magenta {
        background-color: #8d00c4;
        color: #ffffff;
        border: none;
        transition: 0.2s;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(190, 0, 255, 0.4);
        }
</style>

<div class="container mt-5 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-dismissible fade show shadow-sm" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;" role="alert">
            <i class="bi bi-check-circle-fill"></i> <strong>Успех!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="wallet-card shadow-lg h-100">
                <div class="card-body text-center p-5 d-flex flex-column justify-content-center">
                    <i class="bi bi-wallet2 mb-3" style="font-size: 3rem; color: #c4a6ff;"></i>
                    <h5 class="card-title text-uppercase fw-bold mb-3" style="color: #c4a6ff; letter-spacing: 1px;">Текущ Баланс</h5>
                    <h1 class="display-4 fw-bold wallet-balance-text">@Model.ToString("0.00") лв.</h1>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <h3 class="fw-bold mb-4 text-white"><i class="bi bi-cash-coin" style="color: #be00ff;"></i> Добави средства в портфейла</h3>

            <div class="list-group shadow-sm">
                <div class="list-group-item fund-list-item d-flex justify-content-between align-items-center p-4 mb-2 rounded">
                    <span class="fs-5 fw-bold">Добави 10.00 лв.</span>
                    <a asp-action="TopUp" asp-route-amount="10" class="btn btn-magenta px-4 fw-bold">Добави средства</a>
                </div>
                <div class="list-group-item fund-list-item d-flex justify-content-between align-items-center p-4 mb-2 rounded">
                    <span class="fs-5 fw-bold">Добави 20.00 лв.</span>
                    <a asp-action="TopUp" asp-route-amount="20" class="btn btn-magenta px-4 fw-bold">Добави средства</a>
                </div>
                <div class="list-group-item fund-list-item d-flex justify-content-between align-items-center p-4 mb-2 rounded">
                    <span class="fs-5 fw-bold">Добави 50.00 лв.</span>
                    <a asp-action="TopUp" asp-route-amount="50" class="btn btn-magenta px-4 fw-bold">Добави средства</a>
                </div>
                <div class="list-group-item fund-list-item d-flex justify-content-between align-items-center p-4 rounded">
                    <span class="fs-5 fw-bold">Добави 100.00 лв.</span>
                    <a asp-action="TopUp" asp-route-amount="100" class="btn btn-magenta px-4 fw-bold">Добави средства</a>
                </div>
            </div>
        </div>
    </div>
</div>