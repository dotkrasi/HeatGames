@model IEnumerable<HeatGames.Core.DTOs.WishlistDto>

@{
    ViewData["Title"] = "Списък с желания";
}

<h2 class="mt-4 mb-4 fw-bold"><i class="bi bi-heart-fill text-danger"></i> Моят списък с желания</h2>

@if (!Model.Any())
{
    <div class="alert alert-secondary text-center p-5 shadow-sm rounded-lg">
        <i class="bi bi-heartbreak" style="font-size: 3rem;"></i>
        <h4 class="mt-3">Списъкът ви е празен</h4>
        <p>Все още не сте добавили игри, които искате да купите по-късно.</p>
        <a asp-controller="Games" asp-action="Index" class="btn btn-primary mt-2">Разгледай каталога</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-lg">
                    @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                    {
                        <img src="@item.CoverImageUrl" class="card-img-top rounded-top" alt="@item.GameTitle" style="height: 200px; object-fit: cover;">
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@item.GameTitle</h5>
                        <p class="card-text fw-bold text-success fs-5">@item.CurrentPrice лв.</p>
                        <p class="text-muted small">Добавена на: @item.AddedOn.ToString("dd.MM.yyyy")</p>

                        <div class="mt-auto d-grid gap-2">
                            <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="btn btn-success fw-bold">
                                <i class="bi bi-cart"></i> Към магазина
                            </a>

                            @* Бутон за премахване от списъка *@
                            <form asp-controller="Wishlist" asp-action="Toggle" method="post">
                                <input type="hidden" name="gameId" value="@item.GameId" />
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-trash"></i> Премахни
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}