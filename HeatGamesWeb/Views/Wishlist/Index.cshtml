@model IEnumerable<HeatGames.Core.DTOs.WishlistDto>

@{
    ViewData["Title"] = "Списък с желания";
}

<style>
    .wishlist-wrapper {
        background-color: #000000;
        min-height: 80vh;
        color: #e6d9ff;
    }

    /* Стил за Празен списък */
    .empty-wishlist-box {
        background-color: #1a0033;
        border: 1px dashed #4a0080;
        border-radius: 8px;
        padding: 60px 20px;
        text-align: center;
        transition: 0.3s;
    }

        .empty-wishlist-box:hover {
            border-color: #be00ff;
            box-shadow: 0 0 20px rgba(190, 0, 255, 0.1);
        }

    /* Картички за добавени игри */
    .wishlist-card {
        background-color: #1a0033;
        border: 1px solid #4a0080;
        border-radius: 8px;
        transition: 0.3s;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .wishlist-card:hover {
            background-color: #230046;
            border-color: #be00ff;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(190, 0, 255, 0.2);
        }

    .wishlist-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
        border-bottom: 1px solid #4a0080;
        transition: opacity 0.2s;
    }

    .wishlist-card:hover .wishlist-img {
        opacity: 0.9;
    }

    .price-tag {
        color: #be00ff;
        font-weight: bold;
        font-size: 1.3rem;
    }

    /* Бутони */
    .btn-magenta {
        background-color: #8d00c4;
        color: white;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: white;
            transform: scale(1.02);
        }

    .btn-remove-wishlist {
        color: #ff4d4d;
        background: transparent;
        border: 1px solid #4a0080;
        transition: 0.2s;
    }

        .btn-remove-wishlist:hover {
            background: rgba(255, 77, 77, 0.1);
            color: #ff4d4d;
            border-color: #ff4d4d;
        }
</style>

<div class="wishlist-wrapper pt-4">
    <div class="container mb-5">
        <h2 class="fw-bold text-white mb-4 border-bottom border-secondary pb-3">
            <i class="bi bi-heart-fill me-2" style="color: #be00ff;"></i> Моят списък с желания
        </h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success shadow-sm mb-4" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;">
                <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (!Model.Any())
        {
            <div class="empty-wishlist-box shadow-lg mt-4">
                <i class="bi bi-heartbreak" style="font-size: 5rem; color: #4a0080;"></i>
                <h3 class="mt-4 text-white fw-bold">Списъкът ви е празен</h3>
                <p style="color: #acb1b8; font-size: 1.1rem;">Все още не сте добавили игри, които искате да купите по-късно.</p>
                <a asp-controller="Games" asp-action="Index" class="btn btn-magenta mt-3 px-5 py-2 fs-5">
                    <i class="bi bi-controller me-2"></i> Разгледай каталога
                </a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="wishlist-card shadow-sm">
                            <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId">
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@item.CoverImageUrl" class="wishlist-img" alt="@item.GameTitle">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center wishlist-img" style="background-color: #1a0033;">
                                        <i class="bi bi-image" style="font-size: 3rem; color: #4a0080;"></i>
                                    </div>
                                }
                            </a>

                            <div class="card-body p-3 d-flex flex-column flex-grow-1">
                                <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="text-decoration-none text-white">
                                    <h5 class="fw-bold text-truncate mb-1" title="@item.GameTitle">@item.GameTitle</h5>
                                </a>
                                <p class="text-muted small mb-0">Добавена на: @item.AddedOn.ToString("dd.MM.yyyy")</p>

                                <div class="mt-auto pt-3">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="price-tag">
                                            @(item.CurrentPrice == 0 ? "БЕЗПЛАТНО" : item.CurrentPrice.ToString("0.00") + " лв.")
                                        </span>
                                    </div>

                                    <div class="d-flex flex-column gap-2">
                                        <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="btn btn-magenta w-100 py-2">
                                            <i class="bi bi-eye me-1"></i> Виж играта
                                        </a>

                                        <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="m-0">
                                            <input type="hidden" name="gameId" value="@item.GameId" />
                                            <button type="submit" class="btn btn-remove-wishlist w-100 py-2">
                                                <i class="bi bi-trash3 me-1"></i> Премахни
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>  