@model IEnumerable<HeatGames.Core.DTOs.WishlistDto>

@{
    ViewData["Title"] = "My Wishlist";
}

<style>
    .wishlist-card {
        background-color: #1a0033;
        border: 1px solid #4a0080;
        border-radius: 8px;
        transition: 0.3s;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .wishlist-card:hover {
            background-color: #230046;
            border-color: #be00ff;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(190, 0, 255, 0.2);
        }

    .wishlist-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
        border-bottom: 1px solid #4a0080;
        transition: opacity 0.2s;
    }

    .wishlist-card:hover .wishlist-img {
        opacity: 0.9;
    }

    .price-tag {
        color: #be00ff;
        font-weight: bold;
        font-size: 1.3rem;
    }

    .empty-wishlist-box {
        background-color: #1a0033;
        border: 1px dashed #4a0080;
        border-radius: 8px;
        padding: 60px 20px;
        text-align: center;
        transition: 0.3s;
    }

        .empty-wishlist-box:hover {
            border-color: #be00ff;
            box-shadow: 0 0 20px rgba(190, 0, 255, 0.1);
        }

    .btn-magenta {
        background-color: #8d00c4;
        color: white;
        border: none;
        transition: 0.2s;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
    }

        .btn-magenta:hover {
            background-color: #be00ff;
            color: white;
            transform: scale(1.02);
        }

    .btn-remove-wishlist {
        color: #ff4d4d;
        background: transparent;
        border: 1px solid #4a0080;
        transition: 0.2s;
    }

        .btn-remove-wishlist:hover {
            background: rgba(255, 77, 77, 0.1);
            color: #ff4d4d;
            border-color: #ff4d4d;
        }

    .btn-buy {
        background-color: #BEEF52;
        color: #000000;
        font-weight: bold;
        text-transform: uppercase;
        border: none;
        transition: 0.2s;
    }

        .btn-buy:hover {
            background-color: #d1ff70;
            transform: scale(1.02);
            box-shadow: 0 0 10px rgba(190, 239, 82, 0.4);
        }

    .btn-buy-all {
        background-color: transparent;
        color: #BEEF52;
        border: 2px solid #BEEF52;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        padding: 8px 20px;
    }

        .btn-buy-all:hover {
            background-color: #BEEF52;
            color: #000000;
            box-shadow: 0 0 15px rgba(190, 239, 82, 0.4);
        }
</style>

<div class="pt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-3 mb-4">
        <h2 class="fw-bold text-white m-0">
            <i class="bi bi-heart-fill me-2" style="color: #be00ff;"></i> My Wishlist
        </h2>

        @if (Model.Any())
        {
            <form asp-controller="Wishlist" asp-action="AddAllToCart" method="post" class="m-0">
                <button type="submit" class="btn btn-buy-all rounded-pill shadow-sm">
                    <i class="bi bi-cart-plus-fill me-2"></i> Add All To Cart
                </button>
            </form>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm mb-4" style="background-color: #003311; color: #ccffcc; border: 1px solid #00ff00;">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning shadow-sm mb-4" style="background-color: #332200; color: #ffcc66; border: 1px solid #ffaa00;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-wishlist-box shadow-lg mt-4">
            <i class="bi bi-heartbreak" style="font-size: 5rem; color: #4a0080;"></i>
            <h3 class="mt-4 text-white fw-bold">Your wishlist is empty</h3>
            <p style="color: #acb1b8; font-size: 1.1rem;">You haven't added any games to your wishlist yet.</p>
            <a asp-controller="Games" asp-action="Index" class="btn btn-magenta mt-3 px-5 py-2 fs-5">
                <i class="bi bi-controller me-2"></i> Browse Catalog
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="wishlist-card shadow-sm">
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId">
                            @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                            {
                                <img src="@item.CoverImageUrl" class="wishlist-img" alt="@item.GameTitle">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center wishlist-img" style="background-color: #1a0033;">
                                    <i class="bi bi-image" style="font-size: 3rem; color: #4a0080;"></i>
                                </div>
                            }
                        </a>

                        <div class="card-body p-3 d-flex flex-column flex-grow-1">
                            <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="text-decoration-none text-white">
                                <h5 class="fw-bold text-truncate mb-1" title="@item.GameTitle">@item.GameTitle</h5>
                            </a>
                            <p class="text-muted small mb-0">Added on: @item.AddedOn.ToString("dd.MM.yyyy")</p>

                            <div class="mt-auto pt-3">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="price-tag">
                                        @(item.CurrentPrice == 0 ? "FREE" : item.CurrentPrice.ToString("0.00") + " лв.")
                                    </span>
                                </div>

                                <div class="d-flex flex-column gap-2">

                                    <form asp-controller="Wishlist" asp-action="AddToCart" method="post" class="m-0">
                                        <input type="hidden" name="gameId" value="@item.GameId" />
                                        <input type="hidden" name="title" value="@item.GameTitle" />
                                        <input type="hidden" name="coverUrl" value="@item.CoverImageUrl" />
                                        <input type="hidden" name="price" value="@item.CurrentPrice" />
                                        <button type="submit" class="btn btn-buy w-100 py-2">
                                            <i class="bi bi-cart-plus me-1"></i> Add To Cart
                                        </button>
                                    </form>

                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="btn btn-magenta w-100 py-2">
                                        <i class="bi bi-eye me-1"></i> View Details
                                    </a>

                                    <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="m-0">
                                        <input type="hidden" name="gameId" value="@item.GameId" />
                                        <button type="submit" class="btn btn-remove-wishlist w-100 py-2">
                                            <i class="bi bi-trash3 me-1"></i> Remove
                                        </button>
                                    </form>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>